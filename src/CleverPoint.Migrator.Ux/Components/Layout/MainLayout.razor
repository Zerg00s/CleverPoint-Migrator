@namespace CleverPoint.Migrator.Ux.Components.Layout
@inherits LayoutComponentBase
@implements IDisposable
@inject AppStatusService Status
@inject ActivityService Activity
@inject UxSettings Settings
@inject NavigationManager Nav
@inject MigrationRunner Runner
@inject UpdateService Updates
@inject IToastService Toasts
@inject IJSRuntime JS

<FluentDesignTheme @bind-Mode="@_mode" StorageName="theme" />

<div class="app-shell @(_mode == DesignThemeModes.Dark ? "dark" : "light")">

    <header class="app-header">
        <div class="app-header-left">
            <div class="app-brand">
                <span class="app-brand-mark">C</span>
                <div class="app-brand-text">
                    <span class="app-brand-title">CleverPoint Migrator</span>
                    <span class="app-brand-sub">Friendly SharePoint Online Migrator</span>
                </div>
            </div>
        </div>
        <div class="app-header-right">
            <FluentButton Appearance="Appearance.Stealth" Title="Toggle light / dark theme"
                          @onclick="ToggleTheme" IconStart="@_themeIcon" />
        </div>
    </header>

    @if (Status.Current is not null)
    {
        <div class="app-status">
            <FluentMessageBar Intent="@MapIntent(Status.Current.Intent)" AllowDismiss="true"
                              Title="@Status.Current.Intent.ToString()" OnDismiss="@(() => Status.Clear())">
                @Status.Current.Message
            </FluentMessageBar>
        </div>
    }

    <div class="app-main">
        <nav class="app-nav @(_navCollapsed ? "collapsed" : "")">
            <div class="nav-item nav-toggle-item" role="button" @onclick="ToggleNav"
                 title="@(_navCollapsed ? "Expand the navigation" : "Collapse the navigation")">
                <FluentIcon Value="@_navIcon" />
            </div>
            <div class="nav-top-gap"></div>
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All" ActiveClass="active" title="Home">
                <FluentIcon Value="@(new Icons.Regular.Size20.Home())" /> <span>Home</span>
            </NavLink>
            <NavLink class="nav-item" href="explore" ActiveClass="active" title="Copy">
                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowRight())" /> <span>Copy</span>
            </NavLink>
            <NavLink class="nav-item" href="activity" ActiveClass="active" title="Activity">
                <FluentIcon Value="@(new Icons.Regular.Size20.TaskListSquareLtr())" /> <span>Activity</span>
                @if (Runner.ActiveCount > 0)
                {
                    <span class="nav-badge">@Runner.ActiveCount</span>
                }
            </NavLink>
            <NavLink class="nav-item" href="connections" ActiveClass="active" title="Connections">
                <FluentIcon Value="@(new Icons.Regular.Size20.PlugConnected())" /> <span>Connections</span>
            </NavLink>
            @if (HasMultipleTenants)
            {
                <NavLink class="nav-item" href="mapping" ActiveClass="active" title="Identity mapping (cross-tenant)">
                    <FluentIcon Value="@(new Icons.Regular.Size20.PeopleSwap())" /> <span>Mapping</span>
                </NavLink>
            }
            <NavLink class="nav-item" href="history" ActiveClass="active" title="Run History">
                <FluentIcon Value="@(new Icons.Regular.Size20.History())" /> <span>Run History</span>
            </NavLink>
            <NavLink class="nav-item" href="settings" ActiveClass="active" title="Settings">
                <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" /> <span>Settings</span>
            </NavLink>

            <div class="nav-divider"></div>
            <div class="nav-item" role="link" @onclick="@(() => Browser.Open("https://github.com/Zerg00s/CleverPoint-Migrator"))">
                <FluentIcon Value="@(new Icons.Regular.Size20.Link())" /> <span>View on GitHub</span>
                <FluentIcon Value="@(new Icons.Regular.Size16.Open())" Class="nav-ext" Title="Opens in your browser" />
            </div>
            <div class="nav-item" role="link" @onclick="@(() => Browser.Open("https://github.com/Zerg00s/CleverPoint-Migrator/issues"))">
                <FluentIcon Value="@(new Icons.Regular.Size20.Bug())" /> <span>Report an issue</span>
                <FluentIcon Value="@(new Icons.Regular.Size16.Open())" Class="nav-ext" Title="Opens in your browser" />
            </div>
        </nav>

        <main class="app-content">
            <div class="page-transition" @key="_currentPath">
                @Body
            </div>
        </main>
    </div>

    <footer class="app-footer">
        <div class="footer-group">
            <span class="footer-dot @(Runner.ActiveCount > 0 ? "busy" : "online")"></span>
            @if (Runner.ActiveCount > 0)
            {
                <span class="footer-link" role="button" @onclick="@(() => Nav.NavigateTo("/activity"))">
                    @Runner.RunningCount running@(Runner.QueuedCount > 0 ? $", {Runner.QueuedCount} queued" : "")
                </span>
            }
            else
            {
                <span>Ready</span>
            }
            <span class="footer-sep">·</span><span>v@(AppVersion)</span>
        </div>
        <div class="footer-group footer-center">
            <span>CleverPoint Migrator</span>
        </div>
        <div class="footer-group footer-zoom">
            <span class="footer-zoom-btn" role="button" title="Zoom out" @onclick="@(() => ZoomBy(-0.1))">&minus;</span>
            <span class="footer-zoom-pct" role="button" title="Reset zoom to 100%" @onclick="ResetZoom">@((int)Math.Round(_zoom * 100))%</span>
            <span class="footer-zoom-btn" role="button" title="Zoom in" @onclick="@(() => ZoomBy(0.1))">+</span>
        </div>
    </footer>

</div>

<FluentToastProvider MaxToastCount="6" />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />
<FluentKeyCodeProvider />

@code {
    private DesignThemeModes _mode = DesignThemeModes.Light;
    private bool _navCollapsed;
    private string _currentPath = "";

    // From the assembly version stamped at publish time by Sign-App.ps1
    // (-p:Version=X.Y.Z), so the footer always matches the released version.
    private static readonly string AppVersion =
        System.Reflection.Assembly.GetExecutingAssembly().GetName().Version is { } v
            ? $"{v.Major}.{v.Minor}.{v.Build}" : "1.0";

    // Identity mapping is a cross-tenant tool, so only surface it once there are connections to
    // two or more distinct tenants (hosts).
    private bool HasMultipleTenants => Settings.Connections
        .Select(c => { try { return new Uri(c.SiteUrl).Host; } catch { return c.SiteUrl; } })
        .Distinct(StringComparer.OrdinalIgnoreCase).Count() >= 2;

    private Icon _themeIcon => _mode == DesignThemeModes.Dark
        ? new Icons.Regular.Size20.WeatherSunny()
        : new Icons.Regular.Size20.WeatherMoon();

    private Icon _navIcon => _navCollapsed
        ? new Icons.Regular.Size20.PanelLeftExpand()
        : new Icons.Regular.Size20.PanelLeftContract();

    protected override void OnInitialized()
    {
        Settings.EnsureLoaded();
        _mode = Settings.Theme == "Dark" ? DesignThemeModes.Dark : DesignThemeModes.Light;
        Status.OnChange += OnStatusChanged;
        Activity.OnChange += OnStatusChanged;
        Runner.Changed += OnStatusChanged;
        Nav.LocationChanged += OnLocationChanged;
        _currentPath = Nav.Uri;
    }

    // Once per launch (at most once per 24h) quietly check GitHub for a newer release and, if
    // there is one, nudge the user toward Settings > About. Never blocks or errors the UI.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Updates.IsAutoCheckDue()) return;
        try
        {
            var info = await Updates.CheckAsync();
            if (info.Available)
                Toasts.ShowInfo($"Update available: v{info.LatestVersion}. Open Settings, About to update.");
        }
        catch { /* update check is best-effort */ }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentPath = e.Location;
        InvokeAsync(StateHasChanged);
    }

    private void OnStatusChanged() => InvokeAsync(StateHasChanged);
    private void ToggleNav() => _navCollapsed = !_navCollapsed;

    // Page zoom (like a browser). Uses the CSS zoom property via a tiny JS helper; the level
    // survives navigation (this layout persists) and is clamped to a sane range.
    private double _zoom = 1.0;
    private async Task ZoomBy(double delta)
    {
        _zoom = Math.Clamp(Math.Round(_zoom + delta, 2), 0.5, 2.0);
        await JS.InvokeVoidAsync("cpSetZoom", _zoom);
    }
    private async Task ResetZoom()
    {
        _zoom = 1.0;
        await JS.InvokeVoidAsync("cpSetZoom", _zoom);
    }
    private void ToggleTheme()
    {
        _mode = _mode == DesignThemeModes.Dark ? DesignThemeModes.Light : DesignThemeModes.Dark;
        Settings.Theme = _mode == DesignThemeModes.Dark ? "Dark" : "Light";
        Settings.Save();
    }

    private static MessageIntent MapIntent(StatusIntent intent) => intent switch
    {
        StatusIntent.Success => MessageIntent.Success,
        StatusIntent.Warning => MessageIntent.Warning,
        StatusIntent.Error => MessageIntent.Error,
        _ => MessageIntent.Info,
    };

    public void Dispose()
    {
        Status.OnChange -= OnStatusChanged;
        Activity.OnChange -= OnStatusChanged;
        Runner.Changed -= OnStatusChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
