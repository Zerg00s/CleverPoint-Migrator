@page "/run/{Id:long}"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject HistoryService History
@inject NavigationManager Nav

<div class="page-head">
    <h1>Run #@Id</h1>
</div>

@if (_run is null)
{
    <FluentCard>
        <span class="hint">That run could not be found. It may have been deleted.</span>
        <div style="margin-top:14px;">
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                          @onclick="@(() => Nav.NavigateTo("/history"))">Back to Run History</FluentButton>
        </div>
    </FluentCard>
}
else
{
    <FluentCard>
        <div class="run-head">
            <div class="run-title">
                <span class="status-pill @StatusClass(_run)">@Pretty(_run.Status)</span>
                @if (_editingName)
                {
                    <FluentTextField @bind-Value="_nameEdit" Style="min-width:340px;" @onkeydown="NameKey" />
                    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Checkmark())" Title="Save" OnClick="SaveName" />
                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="Cancel" OnClick="@(() => _editingName = false)" />
                }
                else
                {
                    <span class="run-name">@_run.Name</span>
                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Edit())" Title="Rename this task" OnClick="StartRename" />
                }
            </div>
            <div class="btn-row">
                <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.ArrowClockwise())" @onclick="RunAgain">Run again</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                              @onclick="@(() => Nav.NavigateTo("/history"))">Back</FluentButton>
            </div>
        </div>

        <div class="run-meta">
            <div><span class="field-label">Source</span><span>@_run.SourceUrl</span><span class="hint">@_run.SourceList</span></div>
            <div><span class="field-label">Target</span><span>@_run.TargetUrl</span><span class="hint">@_run.TargetList</span></div>
            <div><span class="field-label">Engine</span><span>@(_run.Engine == "MigrationApi" ? "Migration API" : "Classic copy")</span></div>
            <div><span class="field-label">Started</span><span>@_run.StartedUtc.ToLocalTime().ToString("g")</span></div>
            <div><span class="field-label">Finished</span><span>@(_run.FinishedUtc?.ToLocalTime().ToString("g") ?? "—")</span></div>
            <div><span class="field-label">Duration</span><span>@Duration(_run)</span></div>
        </div>

        <div class="run-counts">
            <span class="count ok">@ItemsCopied items copied</span>
            <span class="count">@_items.Count(i => IsItem(i.ItemType) && i.Status == "Skipped") skipped</span>
            <span class="count warn">@_run.Warnings warnings</span>
            <span class="count fail">@_run.Failed failed</span>
        </div>
        <p class="hint" style="margin:6px 0 0;">Items = files, pages and list items. Columns, content types and lists aren't counted.</p>
    </FluentCard>

    <FluentCard style="margin-top:16px;">
        <FluentToolbar Style="width:100%;">
            <span class="section-title" style="margin:0;">Log · @_filteredItems.Count of @_items.Count items</span>
            <FluentSpacer />
            <FluentSearch @bind-Value="_logFilter" @bind-Value:after="ApplyLog" Immediate="true" ImmediateDelay="200" Placeholder="Filter the log…" />
            <FluentSelect TOption="string" @bind-Value="_logStatus" @bind-Value:after="ApplyLog"
                          Items="@_logStatuses" OptionText="@(s => s)" OptionValue="@(s => s)" Style="min-width:160px;" />
        </FluentToolbar>

        <div class="cp-scroll cp-grid" style="height: calc(100vh - 470px); min-height:220px; margin-top:12px;">
            @if (_filteredItems.Count == 0)
            {
                <div style="padding:40px 16px;"><span class="hint">No log rows match.</span></div>
            }
            else
            {
                <FluentDataGrid Items="@_filteredItems.AsQueryable()" Virtualize="true" ItemSize="30" GenerateHeader="GenerateHeaderOption.Sticky"
                                GridTemplateColumns="0.7fr 2.6fr 0.9fr 2.2fr 1.1fr" ShowHover="true" Style="width:100%;"
                                RowClass="@(_ => "click-row")"
                                OnRowClick="@((FluentDataGridRow<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> r) => { _detail = r.Item; return Task.CompletedTask; })">
                    <PropertyColumn Property="@(i => i.ItemType)" Title="Type" />
                    <PropertyColumn Property="@(i => i.SourcePath)" Title="Item" />
                    <TemplateColumn Title="Status">
                        <span class="status-pill @ItemStatusClass(context.Status)">@context.Status</span>
                    </TemplateColumn>
                    <PropertyColumn Property="@(i => i.Message)" Title="Detail" />
                    <PropertyColumn Property="@(i => i.WhenUtc.HasValue ? i.WhenUtc.Value.ToLocalTime().ToString("g") : "")" Title="When" />
                </FluentDataGrid>
            }
        </div>
    </FluentCard>
}

@if (_detail is { } d)
{
    <div class="cp-modal-backdrop" @onclick="@(() => _detail = null)">
        <div class="cp-modal" @onclick:stopPropagation="true">
            <div class="cp-modal-head">
                <span class="status-pill @ItemStatusClass(d.Status)">@d.Status</span>
                <h3 style="margin:0;">@d.ItemType details</h3>
                <FluentSpacer />
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="Close" OnClick="@(() => _detail = null)" />
            </div>
            <div class="cp-modal-body">
                <div class="kv"><span class="k">Type</span><span class="v">@d.ItemType</span></div>
                <div class="kv"><span class="k">Status</span><span class="v">@d.Status</span></div>
                <div class="kv"><span class="k">Source</span><span class="v">@Full(_run?.SourceUrl, d.SourcePath)</span></div>
                <div class="kv"><span class="k">Target</span><span class="v">@Full(_run?.TargetUrl, string.IsNullOrEmpty(d.ItemUrl) ? d.TargetPath : d.ItemUrl)</span></div>
                @if (!string.IsNullOrEmpty(d.Message))
                {
                    <div class="kv"><span class="k">Detail</span><span class="v">@d.Message</span></div>
                }
                @if (d.WhenUtc.HasValue)
                {
                    <div class="kv"><span class="k">When</span><span class="v">@d.WhenUtc.Value.ToLocalTime().ToString("F")</span></div>
                }
            </div>
            <div class="cp-modal-foot">
                @{ var openUrl = Full(_run?.TargetUrl, string.IsNullOrEmpty(d.ItemUrl) ? d.TargetPath : d.ItemUrl); }
                @if (!string.IsNullOrEmpty(openUrl) && openUrl.StartsWith("http"))
                {
                    <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.Open())" OnClick="@(() => Browser.Open(openUrl))">Open target in browser</FluentButton>
                }
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _detail = null)">Close</FluentButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Core.History.MigrationRun? _run;
    private List<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> _items = new();
    private List<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> _filteredItems = new();
    private string _logFilter = "";
    private string _logStatus = "All";
    private readonly string[] _logStatuses = { "All", "Copied", "Skipped", "Warning", "Failed" };

    protected override void OnParametersSet()
    {
        _run = History.GetRun(Id);
        _items = _run is null ? new() : History.GetItems(Id);
        ApplyLog();
    }

    private void ApplyLog()
    {
        IEnumerable<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> q = _items;
        if (!string.IsNullOrWhiteSpace(_logFilter))
        {
            var f = _logFilter.Trim();
            q = q.Where(i => i.SourcePath.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || (i.Message?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                          || i.ItemType.Contains(f, StringComparison.OrdinalIgnoreCase));
        }
        if (_logStatus != "All")
            q = q.Where(i => i.Status == _logStatus);
        _filteredItems = q.ToList();
    }

    // An "item" is a file, a page or a list item — not columns/content types/lists.
    private static bool IsItem(string type) => type is "File" or "Page" or "Item";
    private int ItemsCopied => _items.Count(i => IsItem(i.ItemType) && i.Status == "Copied");

    private (string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)? _detail;

    // Build an absolute URL from a site + (server-relative or already-absolute) path.
    private static string Full(string? site, string path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        if (path.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return path;
        if (string.IsNullOrEmpty(site)) return path;
        try
        {
            var authority = new Uri(site).GetLeftPart(UriPartial.Authority);
            return path.StartsWith("/") ? authority + path : $"{site.TrimEnd('/')}/{path}";
        }
        catch { return path; }
    }

    private bool _editingName;
    private string _nameEdit = "";

    private void StartRename()
    {
        _nameEdit = _run?.Name ?? "";
        _editingName = true;
    }

    private void SaveName()
    {
        var name = _nameEdit.Trim();
        if (_run is not null && name.Length > 0 && name != _run.Name)
        {
            History.RenameRun(_run.Id, name);
            _run.Name = name;
        }
        _editingName = false;
    }

    private void NameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SaveName();
        else if (e.Key == "Escape") _editingName = false;
    }

    private void RunAgain()
    {
        if (_run is null) return;
        var q = $"?src={Uri.EscapeDataString(_run.SourceUrl)}&tgt={Uri.EscapeDataString(_run.TargetUrl)}"
              + $"&lists={Uri.EscapeDataString(_run.SourceList)}";
        Nav.NavigateTo("/wizard" + q);
    }

    private static string Duration(Core.History.MigrationRun r)
    {
        if (r.FinishedUtc is not { } f) return "running…";
        var d = f - r.StartedUtc;
        return d.TotalHours >= 1 ? $"{(int)d.TotalHours}:{d.Minutes:00}:{d.Seconds:00}" : $"{d.Minutes}:{d.Seconds:00}";
    }

    private static string Pretty(string status) => status == "CompletedWithIssues" ? "Completed with issues" : status;

    private static string StatusClass(Core.History.MigrationRun r) => r.Status switch
    {
        "Failed" => "st-failed",
        "CompletedWithIssues" => "st-issues",
        "Interrupted" => "st-interrupted",
        "Running" => "st-running",
        _ => "st-ok",
    };

    private static string ItemStatusClass(string status) => status switch
    {
        "Failed" => "st-failed",
        "Warning" => "st-issues",
        "Skipped" => "st-interrupted",
        _ => "st-ok",
    };
}
