@page "/run/{Id:long}"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@using CleverPoint.Migrator.Ux.Services
@inject HistoryService History
@inject ExplorerState Explorer
@inject PendingMigration Pending
@inject UxMigrationService Migrations
@inject NavigationManager Nav
@inject IToastService Toasts

<div class="page-crumbs">
    <span class="crumb-link" role="button" @onclick="@(() => Nav.NavigateTo("/history"))">Run History</span>
    <span class="crumb-sep">/</span>
    <span class="crumb-current">@(_run?.Name ?? $"Run #{Id}")</span>
</div>

<div class="page-head" style="display:flex; flex-direction:column; gap:8px;">
    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
        @if (_run is null)
        {
            <h1 style="margin:0;">Run #@Id</h1>
        }
        else if (_editingName)
        {
            <FluentTextField @bind-Value="_nameEdit" Style="min-width:380px;" @onkeydown="NameKey" />
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Checkmark())" Title="Save" OnClick="SaveName" />
            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="Cancel" OnClick="@(() => _editingName = false)" />
        }
        else
        {
            <h1 style="margin:0;">@_run.Name</h1>
            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Edit())" Title="Rename this task" OnClick="StartRename" />
        }
    </div>
    @if (_run is not null && !_editingName)
    {
        <div style="display:flex; align-items:center; gap:10px;">
            <span class="status-pill @StatusClass(_run)">@Pretty(_run.Status)</span>
            <span class="hint">Run #@Id</span>
        </div>
    }
</div>

@if (_run is null)
{
    <FluentCard>
        <span class="hint">That run could not be found. It may have been deleted.</span>
        <div style="margin-top:14px;">
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                          @onclick="@(() => Nav.NavigateTo("/history"))">Back to Run History</FluentButton>
        </div>
    </FluentCard>
}
else
{
    <FluentCard>
        <div class="run-head" style="justify-content:flex-end;">
            <div class="btn-row">
                @if (_run.Status == "Interrupted")
                {
                    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Play())" @onclick="Resume"
                                  Title="Continue this interrupted run, skipping the items it already copied">Resume</FluentButton>
                    <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowClockwise())" @onclick="RunAgain">Run again</FluentButton>
                }
                else
                {
                    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.ArrowClockwise())" @onclick="RunAgain">Run again</FluentButton>
                }
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.DocumentCheckmark())"
                              @onclick="@(() => Verify(false))" Disabled="@_verifying"
                              Title="Compare counts + metadata, then produce a client-ready verification report">
                    @(_verifying ? "Verifying…" : "Verify & report")
                </FluentButton>
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.DocumentSearch())"
                              @onclick="@(() => Verify(true))" Disabled="@_verifying"
                              Title="Also hash file contents (SHA-256, slower) for a deeper verification">Deep verify</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.FolderOpen())" @onclick="RestoreInExplorer"
                              Title="Open the explorer at this run's source and target site, library and folder">Return to session</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                              @onclick="@(() => Nav.NavigateTo("/history"))">Back</FluentButton>
            </div>
        </div>

        <div class="section-toggle" role="button" @onclick="@(() => _metaOpen = !_metaOpen)">
            <FluentIcon Value="@((Icon)(_metaOpen ? new Icons.Regular.Size20.ChevronDown() : new Icons.Regular.Size20.ChevronRight()))" />
            <span>Details</span>
        </div>
        @if (_metaOpen)
        {
            <div class="run-meta">
                <div><span class="field-label">Source</span><span>@_run.SourceUrl</span><span class="hint">@_run.SourceList</span></div>
                <div><span class="field-label">Target</span><span>@_run.TargetUrl</span><span class="hint">@_run.TargetList</span></div>
                <div><span class="field-label">Engine</span><span>@(_run.Engine == "MigrationApi" ? "Migration API" : "Classic copy")</span></div>
                <div><span class="field-label">Started</span><span>@_run.StartedUtc.ToLocalTime().ToString("g")</span></div>
                <div><span class="field-label">Finished</span><span>@(_run.FinishedUtc?.ToLocalTime().ToString("g") ?? "Not finished")</span></div>
                <div><span class="field-label">Duration</span><span>@Duration(_run)</span></div>
            </div>
        }

        <div class="run-counts">
            <span class="count ok">@ItemsCopied items copied</span>
            <span class="count">@_items.Count(i => IsItem(i.ItemType) && i.Status == "Skipped") skipped</span>
            <span class="count warn">@_run.Warnings warnings</span>
            <span class="count fail">@_run.Failed failed</span>
        </div>
    </FluentCard>

    <FluentCard style="margin-top:16px;">
        <FluentToolbar Style="width:100%;">
            <span class="section-title" style="margin:0;">Log · @_filteredItems.Count of @_items.Count items</span>
            <FluentSpacer />
            <FluentSearch @bind-Value="_logFilter" @bind-Value:after="ApplyLog" Immediate="true" ImmediateDelay="200" Placeholder="Filter the log…" />
            <FluentSelect TOption="string" @bind-Value="_logStatus" @bind-Value:after="ApplyLog"
                          Items="@_logStatuses" OptionText="@(s => s)" OptionValue="@(s => s)" Style="min-width:160px;" />
            <FluentButton Id="exportLogBtn" Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.ArrowDownload())"
                          @onclick="@(() => _exportOpen = !_exportOpen)" Disabled="@(_items.Count == 0)">Export</FluentButton>
            <FluentMenu Anchor="exportLogBtn" @bind-Open="_exportOpen">
                <FluentMenuItem OnClick="@(() => Export(LogExporter.Format.Csv))">CSV (.csv)</FluentMenuItem>
                <FluentMenuItem OnClick="@(() => Export(LogExporter.Format.Xlsx))">Excel (.xlsx)</FluentMenuItem>
            </FluentMenu>
        </FluentToolbar>

        <div class="cp-scroll cp-grid" style="height: calc(100vh - 470px); min-height:220px; margin-top:12px;">
            @if (_filteredItems.Count == 0)
            {
                <div style="padding:40px 16px;"><span class="hint">No log rows match.</span></div>
            }
            else
            {
                <FluentDataGrid Items="@_filteredItems.AsQueryable()" Virtualize="true" ItemSize="30" GenerateHeader="GenerateHeaderOption.Sticky"
                                GridTemplateColumns="0.9fr 1.2fr 0.9fr 2.4fr 2fr" ShowHover="true" Style="width:100%;"
                                RowClass="@(_ => "click-row")"
                                OnRowClick="@((FluentDataGridRow<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> r) => { _detail = r.Item; return Task.CompletedTask; })">
                    <TemplateColumn Title="Type">
                        <div class="entry-cell">
                            <img class="ft-icon" src="@FileIcons.ForRecord(context.ItemType, context.SourcePath)" alt="" />
                            <span>@FileIcons.FriendlyType(context.ItemType)</span>
                        </div>
                    </TemplateColumn>
                    <PropertyColumn Property="@(i => i.WhenUtc.HasValue ? i.WhenUtc.Value.ToLocalTime().ToString("M/d/yyyy h:mm:ss tt", System.Globalization.CultureInfo.InvariantCulture) : "")" Title="Date" />
                    <TemplateColumn Title="Status">
                        <span class="status-pill @ItemStatusClass(context.Status)">@context.Status</span>
                    </TemplateColumn>
                    <PropertyColumn Property="@(i => i.SourcePath)" Title="Item" />
                    <PropertyColumn Property="@(i => i.Message)" Title="Detail" />
                </FluentDataGrid>
            }
        </div>
    </FluentCard>
}

@if (_detail is { } d)
{
    <div class="cp-modal-backdrop" @onclick="@(() => _detail = null)">
        <div class="cp-modal" @onclick:stopPropagation="true">
            <div class="cp-modal-head">
                <h3 style="margin:0;">@d.ItemType details</h3>
                <FluentSpacer />
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="Close" OnClick="@(() => _detail = null)" />
            </div>
            <div class="cp-modal-body">
                <div class="kv"><span class="k">Type</span><span class="v">@d.ItemType</span></div>
                <div class="kv"><span class="k">Status</span><span class="v">@d.Status</span></div>
                <div class="kv"><span class="k">Source</span><span class="v">@Full(_run?.SourceUrl, d.SourcePath)</span></div>
                <div class="kv"><span class="k">Target</span><span class="v">@Full(_run?.TargetUrl, string.IsNullOrEmpty(d.ItemUrl) ? d.TargetPath : d.ItemUrl)</span></div>
                @if (!string.IsNullOrEmpty(d.Message))
                {
                    <div class="kv"><span class="k">Detail</span><span class="v">@d.Message</span></div>
                }
                @if (d.WhenUtc.HasValue)
                {
                    <div class="kv"><span class="k">When</span><span class="v">@d.WhenUtc.Value.ToLocalTime().ToString("F")</span></div>
                }
            </div>
            <div class="cp-modal-foot">
                @{ var openUrl = Full(_run?.TargetUrl, string.IsNullOrEmpty(d.ItemUrl) ? d.TargetPath : d.ItemUrl); }
                @if (!string.IsNullOrEmpty(openUrl) && openUrl.StartsWith("http"))
                {
                    <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.Open())" OnClick="@(() => Browser.Open(openUrl))">Open target in browser</FluentButton>
                }
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _detail = null)">Close</FluentButton>
            </div>
        </div>
    </div>
}

@if (_exportedPath is not null)
{
    <div class="cp-modal-backdrop" @onclick="@(() => _exportedPath = null)">
        <div class="cp-modal" style="min-height:auto;" @onclick:stopPropagation="true">
            <div class="cp-modal-head">
                <h3 style="margin:0;">Export complete</h3>
                <FluentSpacer />
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="Close" OnClick="@(() => _exportedPath = null)" />
            </div>
            <div class="cp-modal-body">
                <span class="hint">Saved to:</span>
                <span class="v" style="word-break:break-all; user-select:text;">@_exportedPath</span>
            </div>
            <div class="cp-modal-foot">
                <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => _exportedPath = null)">Close</FluentButton>
                <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Open())" OnClick="OpenExported">Open file</FluentButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Core.History.MigrationRun? _run;
    private List<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> _items = new();
    private List<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> _filteredItems = new();
    private string _logFilter = "";
    private string _logStatus = "All";
    private readonly string[] _logStatuses = { "All", "Copied", "Skipped", "Warning", "Failed" };

    private bool _exportOpen;
    private string? _exportedPath;
    private bool _metaOpen;   // Details section starts collapsed.

    private bool _verifying;

    // Compare source vs target and write a client-ready verification report to Downloads. The
    // compare pages every item (and, for deep, hashes files), so it runs on a background thread
    // to keep the UI responsive, with a heads-up toast since large libraries take a while.
    private async Task Verify(bool deep)
    {
        if (_run is null || _verifying) return;
        var run = _run;
        _verifying = true;
        Toasts.ShowInfo(deep
            ? "Deep verification started (hashing file contents). This can take a while for large libraries…"
            : "Verification started. This can take a while for large libraries…");
        StateHasChanged();
        try
        {
            var (report, path) = await Task.Run(() => Migrations.VerifyRunAsync(run, deep));
            _exportedPath = path;   // reuse the "saved to…" modal with an Open button
            if (report.IsClean) Toasts.ShowSuccess($"Verified: {report.Verdict}.");
            else Toasts.ShowWarning($"{report.Mismatches.Count} difference(s) found. See the report.");
        }
        catch (Exception ex)
        {
            Toasts.ShowError($"Verification could not run: {ex.Message}");
        }
        finally
        {
            _verifying = false;
            StateHasChanged();
        }
    }

    // Export the full run log (not just the filtered view) to CSV or XLSX in Downloads,
    // then offer to open it. The chosen format comes from the Export menu.
    private void Export(LogExporter.Format fmt)
    {
        _exportOpen = false;
        if (_run is null) return;
        try
        {
            var headers = new[] { "Type", "Item", "Target", "Status", "Detail", "When" };
            var rows = _items.Select(i => new[]
            {
                i.ItemType, i.SourcePath, i.TargetPath, i.Status, i.Message ?? "",
                i.WhenUtc.HasValue ? i.WhenUtc.Value.ToLocalTime().ToString("g") : "",
            });
            var path = LogExporter.DownloadsPath($"Run {_run.Id} - {_run.Name} log", fmt);
            LogExporter.Write(fmt, path, headers, rows);
            _exportedPath = path;
        }
        catch (Exception ex)
        {
            Toasts.ShowError($"Could not export the log: {ex.Message}");
        }
    }

    private void OpenExported()
    {
        if (_exportedPath is not null) Browser.Open(_exportedPath);
        _exportedPath = null;
    }

    protected override void OnParametersSet()
    {
        _run = History.GetRun(Id);
        _items = _run is null ? new() : History.GetItems(Id);
        ApplyLog();
    }

    private void ApplyLog()
    {
        IEnumerable<(string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)> q = _items;
        if (!string.IsNullOrWhiteSpace(_logFilter))
        {
            var f = _logFilter.Trim();
            q = q.Where(i => i.SourcePath.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || (i.Message?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                          || i.ItemType.Contains(f, StringComparison.OrdinalIgnoreCase));
        }
        if (_logStatus != "All")
            q = q.Where(i => i.Status == _logStatus);
        _filteredItems = q.ToList();
    }

    // An "item" is a file, a page or a list item - not columns/content types/lists.
    private static bool IsItem(string type) => type is "File" or "Page" or "Item";
    private int ItemsCopied => _items.Count(i => IsItem(i.ItemType) && i.Status == "Copied");

    private (string ItemType, string SourcePath, string TargetPath, string Status, string? Message, string? ItemUrl, DateTime? WhenUtc)? _detail;

    // Build an absolute URL from a site + (server-relative or already-absolute) path.
    private static string Full(string? site, string path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        if (path.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return path;
        if (string.IsNullOrEmpty(site)) return path;
        try
        {
            var authority = new Uri(site).GetLeftPart(UriPartial.Authority);
            return path.StartsWith("/") ? authority + path : $"{site.TrimEnd('/')}/{path}";
        }
        catch { return path; }
    }

    private bool _editingName;
    private string _nameEdit = "";

    private void StartRename()
    {
        _nameEdit = _run?.Name ?? "";
        _editingName = true;
    }

    private void SaveName()
    {
        var name = _nameEdit.Trim();
        if (_run is not null && name.Length > 0 && name != _run.Name)
        {
            History.RenameRun(_run.Id, name);
            _run.Name = name;
        }
        _editingName = false;
    }

    private void NameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SaveName();
        else if (e.Key == "Escape") _editingName = false;
    }

    // Rebuild both explorer panes from this run's saved context (site/subsite via the
    // stored web URL, library by title, and folder + selection from the scope) and
    // jump to the explorer positioned exactly where the run started.
    private void RestoreInExplorer()
    {
        if (_run is null) return;
        RunScope? scope = null;
        if (!string.IsNullOrWhiteSpace(_run.ScopeJson))
            try { scope = System.Text.Json.JsonSerializer.Deserialize<RunScope>(_run.ScopeJson!); } catch { }

        Explorer.Source = new PaneSnapshot
        {
            Site = _run.SourceUrl,
            OpenListTitle = _run.SourceList,
            FolderUrl = scope?.SourceFolder ?? "",
            PickedPaths = new(scope?.SelectedPaths ?? new(), StringComparer.OrdinalIgnoreCase),
            PickedIds = new(scope?.ItemIds ?? new()),
        };
        Explorer.Target = new PaneSnapshot
        {
            Site = _run.TargetUrl,
            OpenListTitle = _run.TargetList,
            OpenSubfolderRelative = scope?.TargetSubfolder ?? "",
        };
        Nav.NavigateTo("/explore?restore=1");
    }

    private void RunAgain() => RestoreScopeAndGoToWizard(resume: false);

    // Resume continues an interrupted run: same scope as "Run again", but the wizard also
    // loads this run's already-copied paths into ResumeSkipPaths so only the remainder copies.
    private void Resume() => RestoreScopeAndGoToWizard(resume: true);

    private void RestoreScopeAndGoToWizard(bool resume)
    {
        if (_run is null) return;
        RunScope? scope = null;
        if (!string.IsNullOrWhiteSpace(_run.ScopeJson))
            try { scope = System.Text.Json.JsonSerializer.Deserialize<RunScope>(_run.ScopeJson!); } catch { }

        // Restore the full original scope through Pending so a scoped copy is not re-run as a
        // whole-list copy. Older runs predate IsLibrary/ContentOnly in the scope, so derive
        // sensible fallbacks from the selection.
        var paths = scope?.SelectedPaths ?? new();
        var ids = scope?.ItemIds ?? new();
        Pending.Reset(_run.SourceUrl, _run.TargetUrl);
        Pending.TargetListTitle = string.IsNullOrEmpty(_run.TargetList) ? null : _run.TargetList;
        Pending.TargetListUrl = scope?.TargetListUrl;
        Pending.TargetSubfolderRelative = scope?.TargetSubfolder;
        Pending.ContentOnly = scope?.ContentOnly
            ?? (!string.IsNullOrEmpty(scope?.TargetSubfolder) || paths.Count > 0 || ids.Count > 0);
        if (resume) Pending.ResumeFromRunId = _run.Id;
        Pending.Jobs.Add(new PendingJob
        {
            SourceListTitle = _run.SourceList,
            IsLibrary = scope?.IsLibrary ?? paths.Count > 0,
            SelectedPaths = paths,
            SelectedItemIds = ids,
        });
        Nav.NavigateTo("/wizard");
    }

    private static string Duration(Core.History.MigrationRun r)
    {
        if (r.FinishedUtc is not { } f) return "running…";
        var d = f - r.StartedUtc;
        return d.TotalHours >= 1 ? $"{(int)d.TotalHours}:{d.Minutes:00}:{d.Seconds:00}" : $"{d.Minutes}:{d.Seconds:00}";
    }

    private static string Pretty(string status) => status == "CompletedWithIssues" ? "Completed with issues" : status;

    private static string StatusClass(Core.History.MigrationRun r) => r.Status switch
    {
        "Failed" => "st-failed",
        "CompletedWithIssues" => "st-issues",
        "Interrupted" => "st-interrupted",
        "Running" => "st-running",
        _ => "st-ok",
    };

    private static string ItemStatusClass(string status) => status switch
    {
        "Failed" => "st-failed",
        "Warning" => "st-issues",
        "Skipped" => "st-interrupted",
        "Info" => "st-info",
        _ => "st-ok",
    };
}
