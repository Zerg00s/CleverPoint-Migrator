@page "/settings"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject UxSettings Settings
@inject IToastService Toasts
@inject UpdateService Updates

<div class="page-head">
    <h1>Settings</h1>
</div>

<FluentTabs @bind-ActiveTabId="_tab">
    <FluentTab Id="perf" Label="Performance">
        <div style="padding-top:16px; max-width:640px;">
            <div class="field" style="margin-bottom:18px;">
                <span class="field-label">Maximum parallel migrations</span>
                <FluentNumberField @bind-Value="Settings.MaxParallelMigrations" Min="1" Max="3" Style="width:120px;" />
                <span class="hint">How many migrations run at once. Extra ones queue and start when a slot frees up.
                    All running migrations share one polite request budget, so more is not always faster.</span>
            </div>
            <div class="field" style="margin-bottom:18px;">
                <span class="field-label">Browse cache (minutes)</span>
                <FluentNumberField @bind-Value="Settings.CacheMinutes" Min="1" Max="120" Style="width:120px;" />
                <span class="hint">How long the explorer remembers a site's lists before re-reading.</span>
            </div>
            <div class="field" style="margin-bottom:18px;">
                <span class="field-label">Default migration engine</span>
                <FluentSelect TOption="string" @bind-Value="Settings.DefaultEngine" Style="min-width:340px;">
                    <FluentOption Value="Classic">Classic copy (recommended for most migrations)</FluentOption>
                    <FluentOption Value="MigrationApi">Migration API (best for very large libraries)</FluentOption>
                </FluentSelect>
                <span class="hint">New migrations start with this engine; you can still change it per task.</span>
            </div>
            <div class="field" style="margin-bottom:18px;">
                <span class="field-label">Default file versions to copy</span>
                <FluentNumberField @bind-Value="Settings.DefaultMaxVersions" Min="1" Max="2000" Style="width:140px;" />
                <span class="hint">1 = latest only. Up to 2000. New copy tasks start with this; you can change it per task.</span>
            </div>
            <div class="field" style="margin-bottom:18px;">
                <span class="field-label">Parallel file transfers</span>
                <FluentNumberField @bind-Value="Settings.DefaultParallelFileTransfers" Min="1" Max="16" Style="width:120px;" />
                <span class="hint">Files copied at once within one library copy. 1 = sequential. Higher is faster on many
                    small files; all transfers share one polite request budget, and it falls back to sequential when copying permissions.</span>
            </div>
            <FluentButton Appearance="Appearance.Accent" @onclick="SavePrefs">Save preferences</FluentButton>
        </div>
    </FluentTab>

    <FluentTab Id="adv" Label="Advanced">
        <div style="padding-top:16px; max-width:680px;">
            <div class="section-title">Self-healing (applies after each migration run)</div>
            <FluentCheckbox @bind-Value="Settings.SelfHealAutoRetry" Label="Auto re-run incrementals after a run with failures" />
            <p class="hint" style="margin:4px 0 8px 24px;">Each pass re-copies only what failed or changed; it stops as soon as a pass is clean.</p>
            @if (Settings.SelfHealAutoRetry)
            {
                <div class="field" style="margin:0 0 16px 24px;">
                    <span class="field-label">Maximum retry attempts</span>
                    <FluentNumberField @bind-Value="Settings.SelfHealMaxAttempts" Min="1" Max="5" Style="width:120px;" />
                </div>
            }
            <FluentCheckbox @bind-Value="Settings.SelfHealRepairCorrupt" Label="Detect and re-copy corrupt files (0-byte or truncated on the target)" />
            <p class="hint" style="margin:4px 0 16px 24px;">Only files this tool migrated are ever deleted and replaced.</p>
            <FluentCheckbox @bind-Value="Settings.ShowCompletionToasts" Label="Show a notification when a migration finishes" />
            <div style="margin-top:18px;">
                <FluentButton Appearance="Appearance.Accent" @onclick="SavePrefs">Save preferences</FluentButton>
            </div>
        </div>
    </FluentTab>

    <FluentTab Id="trouble" Label="Troubleshoot">
        <div style="padding-top:16px; max-width:640px;">
            <p class="hint" style="margin-bottom:14px;">Opens the folder with error and crash logs.</p>
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.FolderOpen())"
                          @onclick="OpenLogs">Open Logs</FluentButton>
        </div>
    </FluentTab>

    <FluentTab Id="about" Label="About">
        <div style="padding-top:16px; max-width:640px;">
            <h3 style="margin:0 0 6px 0;">CleverPoint Migrator</h3>
            <p class="hint">
                A SharePoint Online migration tool. It copies lists, libraries, files, folders and pages
                using REST, CSOM and the SPO Migration API. It does not use the Graph API for SharePoint data.
                Created by <a href="#" @onclick:preventDefault @onclick="@(() => Browser.Open("https://github.com/zerg00s"))"
                              style="color:var(--cp-link); cursor:pointer;">Denis Molodtsov</a>.
            </p>
            <div class="btn-row" style="margin-top:14px;">
                <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Link())"
                              @onclick="@(() => Browser.Open("https://github.com/Zerg00s/CleverPoint-Migrator"))">View on GitHub</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.Bug())"
                              @onclick="@(() => Browser.Open("https://github.com/Zerg00s/CleverPoint-Migrator/issues"))">Report an issue</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                              @onclick="CheckUpdates" Disabled="_checking">@(_checking ? "Checking…" : "Check for updates")</FluentButton>
            </div>
            @if (_update is { } u)
            {
                @if (u.Available)
                {
                    <div class="update-card">
                        <div style="display:flex; align-items:center; gap:8px;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowCircleUp())" Color="Color.Accent" />
                            <strong>Update available: v@u.LatestVersion</strong>
                            <span class="hint">(you have v@u.CurrentVersion)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(u.Notes))
                        {
                            <pre class="update-notes">@Trim(u.Notes!)</pre>
                        }
                        <div class="btn-row" style="margin-top:10px;">
                            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.ArrowDownload())"
                                          @onclick="@(() => Install(u))" Disabled="_installing">
                                @(_installing ? "Downloading…" : "Update now")
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.Open())"
                                          @onclick="@(() => Browser.Open(u.ReleaseUrl ?? "https://github.com/Zerg00s/CleverPoint-Migrator/releases"))">Release notes</FluentButton>
                        </div>
                    </div>
                }
                else
                {
                    <p class="hint" style="margin-top:10px;">You're on the latest version.</p>
                }
            }
            <p class="hint" style="margin-top:16px;">Version @AppVersion</p>
            <p class="hint" style="margin-top:4px;">
                Settings stored at
                <a href="#" @onclick:preventDefault @onclick="OpenSettingsFile" style="color:var(--cp-link); cursor:pointer;"><code>@UxSettings.SettingsPath</code></a>
            </p>
        </div>
    </FluentTab>
</FluentTabs>

@code {
    private string _tab = "perf";

    // Comes from the assembly version stamped at publish time by Sign-App.ps1
    // (-p:Version=X.Y.Z), so the About tab always reflects the released version.
    private static readonly string AppVersion =
        System.Reflection.Assembly.GetExecutingAssembly().GetName().Version is { } v
            ? $"{v.Major}.{v.Minor}.{v.Build}" : "1.0";

    protected override void OnInitialized()
    {
        Settings.EnsureLoaded();
        if (Settings.DefaultMaxVersions < 1) Settings.DefaultMaxVersions = 1;
    }

    private void OpenLogs()
    {
        // The folder may not exist yet if nothing has ever been logged; create it
        // so the button always opens something rather than silently doing nothing.
        AppLog.EnsureFolder();
        Browser.Open(AppLog.Folder);
    }

    private void OpenSettingsFile()
    {
        // Ensure the file exists, then open it with the OS default editor.
        if (!File.Exists(UxSettings.SettingsPath)) Settings.Save();
        Browser.Open(UxSettings.SettingsPath);
    }

    private void SavePrefs()
    {
        if (Settings.DefaultMaxVersions < 1) Settings.DefaultMaxVersions = 1;
        Settings.Save();
        Toasts.ShowSuccess("Preferences saved.");
    }

    private UpdateInfo? _update;
    private bool _checking, _installing;

    private async Task CheckUpdates()
    {
        _checking = true;
        try
        {
            _update = await Updates.CheckAsync();   // forced check; also resets the daily timer
            if (_update is { Available: false }) Toasts.ShowInfo("You're on the latest version.");
        }
        catch (Exception ex)
        {
            Toasts.ShowError($"Could not check for updates: {ex.Message}");
        }
        finally { _checking = false; }
    }

    private async Task Install(UpdateInfo u)
    {
        _installing = true;
        try
        {
            if (await Updates.DownloadAndRunInstallerAsync(u))
                Toasts.ShowInfo("The installer is launching. The app will close to finish updating.");
            else
                Browser.Open(u.ReleaseUrl ?? "https://github.com/Zerg00s/CleverPoint-Migrator/releases");
        }
        catch (Exception ex)
        {
            Toasts.ShowError($"Update failed: {ex.Message}. Opening the release page instead.");
            Browser.Open(u.ReleaseUrl ?? "https://github.com/Zerg00s/CleverPoint-Migrator/releases");
        }
        finally { _installing = false; }
    }

    // Keep the release-notes preview short.
    private static string Trim(string notes) =>
        notes.Length > 600 ? notes[..600].TrimEnd() + "…" : notes;
}
