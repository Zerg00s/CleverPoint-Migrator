@page "/"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject NavigationManager Nav
@inject UxSettings Settings
@inject HistoryService History

@if (_noConnections)
{
    <div class="empty-state">
        <div class="empty-art">
            <FluentIcon Value="@(new Icons.Regular.Size48.PlugConnected())" Color="Color.Accent" />
        </div>
        <h1 style="margin:0;">Welcome to CleverPoint Migrator</h1>
        <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())"
                      @onclick="@(() => Nav.NavigateTo("/connections?add=1"))">Add your first connection</FluentButton>
    </div>
}
else
{
    <section class="hero section">
        <h1>Copy SharePoint Online content with ease</h1>
        <p>
            Copy lists, libraries, files, folders and pages across sites, subsites and tenants, preserving
            authors, dates, versions, content types and permissions.
        </p>
        <div class="btn-row">
            <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Nav.NavigateTo("/explore"))"
                          IconStart="@(new Icons.Regular.Size20.ArrowRight())">New copy task</FluentButton>
            <FluentButton Appearance="Appearance.Lightweight" @onclick="@(() => Nav.NavigateTo("/history"))"
                          IconStart="@(new Icons.Regular.Size20.History())">View history</FluentButton>
        </div>
    </section>

    <div class="section">
        <h2 class="section-title">Recent migrations</h2>
        <RunsTable PageSize="8" ShowPageSize="false" />
    </div>
}

@code {
    private bool _noConnections;
    private List<Core.History.MigrationRun> _runs = new();
    private IQueryable<Core.History.MigrationRun> _recent = Enumerable.Empty<Core.History.MigrationRun>().AsQueryable();
    private long _totalCopied;
    private int _withIssues;

    protected override void OnInitialized()
    {
        Settings.EnsureLoaded();
        _noConnections = Settings.Connections.Count == 0;
        _runs = History.GetRuns();
        _recent = _runs.Take(12).AsQueryable();
        _totalCopied = _runs.Sum(r => (long)r.Copied);
        _withIssues = _runs.Count(r => r.Failed > 0 || r.Status is "Failed" or "CompletedWithIssues");
    }

    private static string Pretty(string status) => status == "CompletedWithIssues" ? "Completed with issues" : status;

    private static string StatusColor(Core.History.MigrationRun r) =>
        r.Failed > 0 || r.Status == "Failed" ? "#b02a37"
        : r.Warnings > 0 || r.Status is "CompletedWithIssues" or "Interrupted" ? "#b8860b" : "#1e7e34";
}
