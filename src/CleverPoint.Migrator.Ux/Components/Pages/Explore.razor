@page "/explore"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@using CleverPoint.Migrator.Ux.Services
@inject NavigationManager Nav
@inject IToastService Toasts
@inject PendingMigration Pending
@inject DragState Drag
@inject ExplorerState State

<div class="page-head">
    <h1>Copy</h1>
    <p>Open a source on the left and a target on the right, tick what to copy, then start the migration.</p>
</div>

<div class="explorer">
    @if (_showArrow)
    {
        <div class="explorer-hints" aria-hidden="true">
            <div class="eh eh-left">
                <FluentIcon Value="@(new Icons.Regular.Size32.Folder())" />
                <span>Drag a file or folder</span>
            </div>
            <svg class="explorer-arrow" viewBox="0 0 260 100" fill="none" stroke="currentColor"
                 stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 16 76 Q 128 12 224 50" />
                <path d="M 203 26 L 227 51 L 191 55" />
            </svg>
            <div class="eh eh-right">
                <FluentIcon Value="@(new Icons.Regular.Size32.ArrowDownload())" />
                <span>Drop on the target</span>
            </div>
        </div>
    }
    <ExplorerPane @ref="_source" Role="Source" IsSource="true" OnChanged="OnPaneChanged" />
    <ExplorerPane @ref="_target" Role="Target" IsSource="false" OnChanged="OnPaneChanged" OnDropRequested="OnDropToTarget" />
</div>

<div class="copy-bar">
    @if (_blockedReason is { } reason)
    {
        <div class="copy-blocked"><FluentIcon Value="@(new Icons.Regular.Size20.Warning())" /> @reason</div>
    }
    <FluentButton Appearance="Appearance.Accent" Class="cp-cta" Disabled="@(!_canCopy || _blockedReason is not null)"
                  IconEnd="@(new Icons.Regular.Size24.ArrowRight())" @onclick="StartCopy"
                  Title="@(_canCopy ? "Start the migration" : "Open a source list and a target connection first")">Copy to target</FluentButton>
</div>

@code {
    private ExplorerPane? _source;
    private ExplorerPane? _target;
    private bool _canCopy;
    private bool _showArrow = true;

    private string? _blockedReason;

    // Set to "1" by "Back to explorer" (wizard) and "Restore in explorer" (history).
    // A plain Copy navigation has no query, so it starts fresh. Carrying intent in the
    // URL is deterministic even if the page initializes more than once per navigation.
    [SupplyParameterFromQuery(Name = "restore")] public string? RestoreParam { get; set; }

    protected override void OnInitialized()
    {
        if (RestoreParam != "1")
        {
            State.Source = null;
            State.Target = null;
        }
    }

    private void OnPaneChanged()
    {
        _canCopy = (_source?.IsReady ?? false) && (_target?.IsReady ?? false);
        // Subtle direction hint, only while nothing is connected yet.
        _showArrow = !(_source?.HasConnection ?? false) && !(_target?.HasConnection ?? false);
        _blockedReason = ComputeBlockedReason();
        StateHasChanged();
    }

    // Structure copies (whole lists/libraries) recreate a list at the target site root.
    // That's incompatible with dropping into a folder, or merging many lists into one
    // open list. Item-selection copies are content-only and may target an open list/folder.
    private string? ComputeBlockedReason()
    {
        if (_source is null || _target is null) return null;
        var tickedCount = _source.SelectedLists.Count;

        // Ticked lists are whole-list STRUCTURE copies: each is recreated at the target
        // SITE root, so it can't land inside a folder, and several can't merge into one
        // list. A single OPEN source list (even at its root, with nothing picked) is fine
        // to copy INTO an open target list/folder as a content copy, so it is NOT blocked.
        if (tickedCount > 0)
        {
            if (_target.IsInSubfolder)
                return "You ticked a whole list or library, which is recreated at the target site. Open the target at its site (not inside a folder) - or open a single source list and copy its files into this folder instead.";
            if (_target.IsListOpen)
                return tickedCount >= 2
                    ? "You picked several lists/libraries but the target is a single open list. Open the target at its site so each one is created there."
                    : "You ticked a list/library, which is recreated at the target site (not into the open target list). Open the target at its site, or open a single source list to copy its content into this list.";
        }
        return null;
    }

    // Files/folders dragged from the source were dropped on the target pane.
    // Dropped items go INTO the library/list currently open on the target.
    private void OnDropToTarget()
    {
        if (!Drag.Active) return;
        if (_target?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a target connection on the right first.");
            return;
        }
        if (_target.CurrentList is null)
        {
            Toasts.ShowWarning("Open the target library or list on the right, then drop the items into it.");
            Drag.End();
            return;
        }
        Pending.Reset(Drag.SourceSite, _target.SiteUrl);
        Pending.TargetListTitle = _target.CurrentList.Title;
        Pending.TargetSubfolderRelative = _target.CurrentSubfolderRelative;   // drop into the open target folder
        Pending.ContentOnly = true;
        Pending.Jobs.Add(new PendingJob
        {
            SourceListTitle = Drag.SourceListTitle,
            IsLibrary = Drag.IsLibrary,
            SelectedPaths = Drag.Paths.ToList(),
            SelectedItemIds = Drag.ItemIds.ToList(),
            SelectedFolderCount = Drag.FolderCount,
            SelectedFileCount = Drag.FileCount,
        });
        Drag.End();
        Nav.NavigateTo("/wizard");
    }

    private void StartCopy()
    {
        if (_source?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a source connection on the left.");
            return;
        }
        if (_target?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a target connection on the right.");
            return;
        }

        // Ticked lists take priority: copy each whole list/library in one batch.
        // Otherwise use the open list, carrying any ticked files/folders/items.
        Pending.Reset(_source.SiteUrl, _target.SiteUrl);
        var ticked = _source.SelectedLists;
        if (ticked.Count > 0)
        {
            foreach (var l in ticked)
                Pending.Jobs.Add(new PendingJob { SourceListTitle = l.Title, IsLibrary = l.IsLibrary });
        }
        else if (_source.CurrentList is not null)
        {
            // If a target list/folder is open, land content INTO it: this covers both a
            // specific item selection AND copying a whole source list's contents into the
            // open target folder (no items picked = copy everything). With no target list
            // open, this is a structure copy that recreates the source list at the site.
            var hasSelection = _source.SelectedPaths.Count > 0 || _source.SelectedItemIds.Count > 0;
            if (_target.CurrentList is not null)
            {
                Pending.TargetListTitle = _target.CurrentList.Title;
                Pending.TargetSubfolderRelative = _target.CurrentSubfolderRelative;   // into the open target folder
                Pending.ContentOnly = true;
            }
            else if (hasSelection)
            {
                Toasts.ShowWarning("Open the target library or list on the right to copy the selected items into it.");
                return;
            }
            Pending.Jobs.Add(new PendingJob
            {
                SourceListTitle = _source.CurrentList.Title,
                IsLibrary = _source.CurrentListIsLibrary,
                // Nothing ticked = "copy what is in the folder I have open". Without this, an unticked copy
                // meant the whole LIBRARY, so standing in Folder-A/Sub-1 copied every file from the list
                // root into the target folder. A tick list carries its own paths, and at the list root this
                // stays null = whole list, both as before.
                SourceFolder = !hasSelection && _source.IsInSubfolder
                    ? _source.CurrentFolderServerRelativeUrl : null,
                SelectedPaths = _source.SelectedPaths,
                SelectedItemIds = _source.SelectedItemIds,
                SelectedFolderCount = _source.SelectedFolderCount,
                SelectedFileCount = _source.SelectedFileCount,
            });
        }
        else
        {
            Toasts.ShowWarning("Tick one or more lists, or open a list to pick items.");
            return;
        }

        Nav.NavigateTo("/wizard");
    }
}
