@page "/explore"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject NavigationManager Nav
@inject IToastService Toasts
@inject PendingMigration Pending
@inject DragState Drag

<div class="page-head">
    <h1>Copy</h1>
    <p>Open a source on the left and a target on the right, tick what to copy, then start the migration.</p>
</div>

<div class="explorer">
    @if (_showArrow)
    {
        <div class="explorer-hints" aria-hidden="true">
            <div class="eh eh-left">
                <FluentIcon Value="@(new Icons.Regular.Size32.Folder())" />
                <span>Drag a file or folder</span>
            </div>
            <svg class="explorer-arrow" viewBox="0 0 260 100" fill="none" stroke="currentColor"
                 stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 16 76 Q 128 12 224 50" />
                <path d="M 203 26 L 227 51 L 191 55" />
            </svg>
            <div class="eh eh-right">
                <FluentIcon Value="@(new Icons.Regular.Size32.ArrowDownload())" />
                <span>Drop on the target</span>
            </div>
        </div>
    }
    <ExplorerPane @ref="_source" Role="Source" IsSource="true" OnChanged="OnPaneChanged" />
    <ExplorerPane @ref="_target" Role="Target" IsSource="false" OnChanged="OnPaneChanged" OnDropRequested="OnDropToTarget" />
</div>

<div class="copy-bar">
    <FluentButton Appearance="Appearance.Accent" Class="cp-cta" Disabled="@(!_canCopy)"
                  IconEnd="@(new Icons.Regular.Size24.ArrowRight())" @onclick="StartCopy"
                  Title="@(_canCopy ? "Start the migration" : "Open a source list and a target connection first")">Copy to target</FluentButton>
</div>

@code {
    private ExplorerPane? _source;
    private ExplorerPane? _target;
    private bool _canCopy;
    private bool _showArrow = true;

    private void OnPaneChanged()
    {
        _canCopy = (_source?.IsReady ?? false) && (_target?.IsReady ?? false);
        // Subtle direction hint, only while nothing is connected yet.
        _showArrow = !(_source?.HasConnection ?? false) && !(_target?.HasConnection ?? false);
        StateHasChanged();
    }

    // Files/folders dragged from the source were dropped on the target pane.
    // Dropped items go INTO the library/list currently open on the target.
    private void OnDropToTarget()
    {
        if (!Drag.Active) return;
        if (_target?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a target connection on the right first.");
            return;
        }
        if (_target.CurrentList is null)
        {
            Toasts.ShowWarning("Open the target library or list on the right, then drop the items into it.");
            Drag.End();
            return;
        }
        Pending.Reset(Drag.SourceSite, _target.SiteUrl);
        Pending.TargetListTitle = _target.CurrentList.Title;
        Pending.ContentOnly = true;
        Pending.Jobs.Add(new PendingJob
        {
            SourceListTitle = Drag.SourceListTitle,
            IsLibrary = Drag.IsLibrary,
            SelectedPaths = Drag.Paths.ToList(),
            SelectedItemIds = Drag.ItemIds.ToList(),
            SelectedFolderCount = Drag.FolderCount,
            SelectedFileCount = Drag.FileCount,
        });
        Drag.End();
        Nav.NavigateTo("/wizard");
    }

    private void StartCopy()
    {
        if (_source?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a source connection on the left.");
            return;
        }
        if (_target?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a target connection on the right.");
            return;
        }

        // Ticked lists take priority: copy each whole list/library in one batch.
        // Otherwise use the open list, carrying any ticked files/folders/items.
        Pending.Reset(_source.SiteUrl, _target.SiteUrl);
        var ticked = _source.SelectedLists;
        if (ticked.Count > 0)
        {
            foreach (var l in ticked)
                Pending.Jobs.Add(new PendingJob { SourceListTitle = l.Title, IsLibrary = l.IsLibrary });
        }
        else if (_source.CurrentList is not null)
        {
            // A specific item selection is content-only: it must go into an existing
            // target list, so require one to be open on the right.
            var hasSelection = _source.SelectedPaths.Count > 0 || _source.SelectedItemIds.Count > 0;
            if (hasSelection)
            {
                if (_target.CurrentList is null)
                {
                    Toasts.ShowWarning("Open the target library or list on the right to copy the selected items into it.");
                    return;
                }
                Pending.TargetListTitle = _target.CurrentList.Title;
                Pending.ContentOnly = true;
            }
            Pending.Jobs.Add(new PendingJob
            {
                SourceListTitle = _source.CurrentList.Title,
                IsLibrary = _source.CurrentListIsLibrary,
                SelectedPaths = _source.SelectedPaths,
                SelectedItemIds = _source.SelectedItemIds,
                SelectedFolderCount = _source.SelectedFolderCount,
                SelectedFileCount = _source.SelectedFileCount,
            });
        }
        else
        {
            Toasts.ShowWarning("Tick one or more lists, or open a list to pick items.");
            return;
        }

        Nav.NavigateTo("/wizard");
    }
}
