@page "/explore"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject NavigationManager Nav
@inject IToastService Toasts

<div class="page-head">
    <h1>Copy</h1>
    <p>Open a source on the left and a target on the right, tick what to copy, then start the migration.</p>
</div>

<div class="explorer">
    <ExplorerPane @ref="_source" Role="Source" IsSource="true" OnChanged="OnPaneChanged" />
    <ExplorerPane @ref="_target" Role="Target" IsSource="false" OnChanged="OnPaneChanged" />
</div>

<div class="copy-bar">
    <FluentButton Appearance="Appearance.Accent" Class="cp-cta" Disabled="@(!_canCopy)"
                  IconStart="@(new Icons.Regular.Size24.ArrowSwap())" @onclick="StartCopy"
                  Title="@(_canCopy ? "Start the migration" : "Open a source list and a target connection first")">Copy to target&nbsp;&nbsp;&gt;</FluentButton>
</div>

@code {
    private ExplorerPane? _source;
    private ExplorerPane? _target;
    private bool _canCopy;

    private void OnPaneChanged()
    {
        _canCopy = (_source?.IsReady ?? false) && (_target?.IsReady ?? false);
        StateHasChanged();
    }

    private void StartCopy()
    {
        if (_source?.CurrentList is null || _source.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a source list or library first.");
            return;
        }
        if (_target?.SiteUrl is null)
        {
            Toasts.ShowWarning("Open a target connection on the right.");
            return;
        }
        var selected = _source.SelectedEntries;
        var lists = _source.CurrentList.Title;
        var q = $"?src={Uri.EscapeDataString(_source.SiteUrl)}&tgt={Uri.EscapeDataString(_target.SiteUrl)}"
              + $"&lists={Uri.EscapeDataString(lists)}";
        if (selected.Count > 0)
            q += $"&items={selected.Count}";
        Nav.NavigateTo("/wizard" + q);
    }
}
