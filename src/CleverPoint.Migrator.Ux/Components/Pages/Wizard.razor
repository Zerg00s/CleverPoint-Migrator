@page "/wizard"
@namespace CleverPoint.Migrator.Ux.Components.Pages
@inject NavigationManager Nav
@inject IToastService Toasts
@inject UxMigrationService Migrations
@inject ActivityService Activity
@inject UxSettings Settings
@inject PendingMigration Pending
@inject HistoryService History
@inject MigrationRunner Runner
@inject BrowserSignIn SignIn

<div class="page-head wizard-head">
    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                  Disabled="_running" @onclick="@(() => Nav.NavigateTo("/explore"))">Back to explorer</FluentButton>
    <h1>New Copy Task</h1>
</div>

<FluentCard>
    @if (!_batch)
    {
        <div class="field" style="max-width:520px; margin-bottom:18px;">
            <span class="field-label">Task name</span>
            <FluentTextField @bind-Value="_taskName" Style="width:100%;" Disabled="_running" />
        </div>
    }

    <div class="copy-setup">
        <div class="cs-side cs-source">
            <div class="cs-head">Source</div>
            <div class="ro-field">
                <span class="field-label">Site</span>
                <div class="ro-value">@_src</div>
            </div>
            <div class="ro-field">
                <span class="field-label">@(_batch ? "Lists & libraries" : "List / library")</span>
                @if (_batch)
                {
                    <ul class="batch-list">
                        @foreach (var j in _jobs)
                        {
                            <li>@j.SourceListTitle @(j.WholeList ? "" : $"({(j.IsLibrary ? j.SelectedPaths.Count : j.SelectedItemIds.Count)} selected)")</li>
                        }
                    </ul>
                }
                else
                {
                    <div class="ro-value">@_list</div>
                    @if (_jobs.Count == 1 && !_jobs[0].WholeList)
                    {
                        <span class="hint">Copying @(_jobs[0].IsLibrary ? _jobs[0].SelectedPaths.Count : _jobs[0].SelectedItemIds.Count) selected
                            @(_jobs[0].IsLibrary ? "files/folders" : "items") only. Folders bring their contents.</span>
                    }
                }
            </div>
        </div>

        <div class="cs-arrow"><FluentIcon Value="@(new Icons.Regular.Size32.ArrowRight())" /></div>

        <div class="cs-side cs-target">
            <div class="cs-head">Target</div>
            <div class="ro-field">
                <span class="field-label">Site</span>
                <div class="ro-value">@_tgt</div>
            </div>
            @if (_batch)
            {
                <span class="hint">Each list is created on the target under its own name@(_sameSite ? " with “ - Copy” appended" : "").</span>
            }
            else if (_targetLocked)
            {
                <div class="ro-field">
                    <span class="field-label">Target list</span>
                    <div class="ro-value">@_targetTitle</div>
                </div>
                <span class="hint">Items are added to this existing list, so the name and URL are fixed.</span>
            }
            else
            {
                <div class="field" style="margin-bottom:10px;">
                    <span class="field-label">Target list title</span>
                    <FluentTextField @bind-Value="_targetTitle" @bind-Value:after="CheckTargetAsync" Immediate="true" ImmediateDelay="400"
                                     Style="width:100%;" Disabled="_running" />
                </div>
                <div class="field">
                    <span class="field-label">Target list URL (the part after the site)</span>
                    <FluentTextField @bind-Value="_targetUrl" @bind-Value:after="StateHasChanged" Immediate="true"
                                     Style="width:100%;" Disabled="_running" Placeholder="e.g. Lists/MyList or MyLibrary" />
                    <span class="url-preview">@FullTargetUrl()</span>
                </div>
            }
            @if (!_batch && _targetState != TargetState.Unknown)
            {
                <span class="target-chip @TargetChipClass">@_targetStateMsg</span>
            }
        </div>
    </div>

    <div class="section-title" style="margin-top:22px;">Options</div>
    <div class="grid cols-2" style="gap:14px 28px; margin-bottom:6px;">
        <div class="field">
            <span class="field-label">Copy mode</span>
            @if (_lockContentOnly)
            {
                <div class="ro-value">Content only</div>
                <span class="hint">You picked specific items, so they're added to the target list (no structure to recreate).</span>
            }
            else
            {
                <FluentSelect TOption="string" @bind-Value="_copyMode" Style="width:100%;" Disabled="_running">
                    <FluentOption Value="full">Structure + content (recreate the list, then copy items)</FluentOption>
                    <FluentOption Value="content">Content only (target list already exists)</FluentOption>
                </FluentSelect>
            }
        </div>
        <div class="field">
            <span class="field-label">Engine</span>
            <FluentSelect TOption="string" @bind-Value="_engine" Style="width:100%;" Disabled="_running">
                <FluentOption Value="Classic">Classic copy (recommended for most migrations)</FluentOption>
                <FluentOption Value="MigrationApi">Migration API (best for very large libraries)</FluentOption>
            </FluentSelect>
        </div>
        <div class="field">
            <span class="field-label">File versions to copy</span>
            <FluentNumberField @bind-Value="_maxVersions" Min="1" Max="2000" Style="width:140px;" Disabled="_running" />
            <span class="hint">1 = latest only. Up to 2000.</span>
        </div>
        <div class="field">
            <span class="field-label">If the item already exists on the target</span>
            <FluentSelect TOption="string" @bind-Value="_existingMode" Style="width:100%;" Disabled="_running">
                <FluentOption Value="Overwrite">Overwrite (replace the target copy)</FluentOption>
                <FluentOption Value="CopyIfNewer">Copy if newer (skip when the target is up to date)</FluentOption>
                <FluentOption Value="Skip">Skip (leave existing target items alone)</FluentOption>
            </FluentSelect>
        </div>
    </div>

    <div class="section-title" style="margin-top:18px;">Date filter (optional)</div>
    <FluentCheckbox @bind-Value="_useDateFilter" Label="Only copy items within a date range" Disabled="_running" />
    @if (_useDateFilter)
    {
        <div class="grid cols-2" style="gap:14px 28px; margin-top:10px; max-width:760px;">
            <div class="field">
                <span class="field-label">Based on</span>
                <FluentSelect TOption="string" @bind-Value="_dateField" Style="width:100%;" Disabled="_running">
                    <FluentOption Value="Modified">Last modified date</FluentOption>
                    <FluentOption Value="Created">Created date</FluentOption>
                </FluentSelect>
            </div>
            <div></div>
            <div class="field">
                <span class="field-label">From (on or after)</span>
                <div style="display:flex; gap:8px;">
                    <FluentDatePicker @bind-Value="_dateFrom" Disabled="_running" Style="flex:1 1 auto;" />
                    <FluentTimePicker @bind-Value="_timeFrom" Disabled="_running" Style="width:130px;" />
                </div>
            </div>
            <div class="field">
                <span class="field-label">To (on or before)</span>
                <div style="display:flex; gap:8px;">
                    <FluentDatePicker @bind-Value="_dateTo" Disabled="_running" Style="flex:1 1 auto;" />
                    <FluentTimePicker @bind-Value="_timeTo" Disabled="_running" Style="width:130px;" />
                </div>
            </div>
            <div></div>
            <span class="hint">Times are in your local timezone. Leave a time blank to include the whole day.</span>
        </div>
    }

    <div class="grid cols-2" style="gap:8px 28px; margin:10px 0 4px;">
        <FluentCheckbox @bind-Value="_preserve" Label="Preserve authors and dates" Disabled="_running" />
        @if (_showAttachments)
        {
            <FluentCheckbox @bind-Value="_attachments" Label="Copy attachments" Disabled="_running" />
        }
        <FluentCheckbox @bind-Value="_permissions" Label="Copy unique permissions" Disabled="_running" />
        <FluentCheckbox @bind-Value="_contentTypes" Label="Copy content types &amp; site columns" Disabled="_running" />
    </div>

    @if (BeginBlockedReason is { } reason)
    {
        <div style="margin-top:16px;">
            <FluentMessageBar Intent="MessageIntent.Warning">@reason</FluentMessageBar>
        </div>
    }
    <div class="begin-bar">
        <FluentButton Appearance="Appearance.Accent" Class="cp-cta" IconStart="@(new Icons.Regular.Size24.Play())"
                      Disabled="@(BeginBlockedReason is not null)" @onclick="Start">Begin copy</FluentButton>
    </div>

    @if (_status is not null)
    {
        <div style="margin-top:14px;">
            <FluentMessageBar Intent="@_statusIntent">@_status</FluentMessageBar>
        </div>
    }
</FluentCard>

@code {
    [SupplyParameterFromQuery(Name = "src")] public string? Src { get; set; }
    [SupplyParameterFromQuery(Name = "tgt")] public string? Tgt { get; set; }
    [SupplyParameterFromQuery(Name = "lists")] public string? Lists { get; set; }

    private string _src = "", _tgt = "", _list = "", _taskName = "", _targetTitle = "", _targetUrl = "", _engine = "Classic";
    private string _copyMode = "full";
    private bool _lockContentOnly;
    private bool _targetLocked;
    private int _maxVersions = 1;
    private string _existingMode = "Overwrite";
    private bool _useDateFilter;
    private string _dateField = "Modified";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private DateTime? _timeFrom;
    private DateTime? _timeTo;
    private List<PendingJob> _jobs = new();
    private bool _batch, _sameSite;
    private bool _preserve = true, _attachments = true, _permissions, _contentTypes = true;

    // Attachments only apply to list items; libraries don't have them.
    private bool _showAttachments => !(_jobs.Count == 1 && _jobs[0].IsLibrary);

    private enum TargetState { Unknown, New, Exists, Mismatch }
    private TargetState _targetState = TargetState.Unknown;
    private string _targetStateMsg = "";
    private string TargetChipClass => _targetState switch
    {
        TargetState.New => "st-ok",
        TargetState.Exists => "st-running",
        TargetState.Mismatch => "st-issues",
        _ => "",
    };

    // Block Begin only for genuinely-broken combos; everything else is allowed.
    private string? BeginBlockedReason =>
        _targetState == TargetState.Mismatch ? _targetStateMsg
        : (_copyMode == "content" && _targetState == TargetState.New)
            ? "Content-only needs an existing target list, but this one doesn't exist yet. Switch to Structure + content, or point at an existing list."
        : null;
    private const bool _running = false;   // execution moved to the background runner
    private string? _status;
    private MessageIntent _statusIntent = MessageIntent.Info;

    protected override void OnInitialized()
    {
        // Selection comes from the explorer via PendingMigration; query params are a
        // fallback for a direct/stale navigation.
        if (Pending.Jobs.Count > 0)
        {
            _src = Pending.SourceSite;
            _tgt = Pending.TargetSite;
            _jobs = Pending.Jobs.Select(j => new PendingJob
            {
                SourceListTitle = j.SourceListTitle, IsLibrary = j.IsLibrary,
                SelectedPaths = j.SelectedPaths.ToList(), SelectedItemIds = j.SelectedItemIds.ToList(),
                SelectedFolderCount = j.SelectedFolderCount, SelectedFileCount = j.SelectedFileCount,
            }).ToList();
        }
        else
        {
            _src = Src ?? "";
            _tgt = Tgt ?? "";
            _jobs = (Lists ?? "").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(t => new PendingJob { SourceListTitle = t }).ToList();
        }
        _batch = _jobs.Count > 1;
        // Picking specific files/folders/items means there's no structure to recreate;
        // lock to content-only so "Structure + content" isn't offered.
        _lockContentOnly = Pending.ContentOnly || _jobs.Any(j => !j.WholeList);
        if (_lockContentOnly) _copyMode = "content";
        _list = _jobs.FirstOrDefault()?.SourceListTitle ?? "";
        _sameSite = string.Equals(_src.TrimEnd('/'), _tgt.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
        // When copying a selection into an already-open target list, use that list
        // (content-only); otherwise default to a new list named after the source.
        if (!string.IsNullOrWhiteSpace(Pending.TargetListTitle))
        {
            _targetTitle = Pending.TargetListTitle!;
            _targetUrl = string.IsNullOrWhiteSpace(Pending.TargetListUrl) ? DefaultUrl(_targetTitle) : Pending.TargetListUrl!;
            _targetLocked = true;
        }
        else
        {
            _targetTitle = _sameSite && _list.Length > 0 ? $"{_list} - Copy" : _list;
            _targetUrl = DefaultUrl(_targetTitle);
        }
        // Name the task by what it copies. A specific selection reads
        // "Copy 2 folders and 3 files from LMAS to cleverpointlab".
        var sel = _jobs.Count == 1 && !_jobs[0].WholeList ? _jobs[0] : null;
        if (sel is not null)
        {
            var parts = new List<string>();
            if (sel.SelectedFolderCount > 0) parts.Add($"{sel.SelectedFolderCount} folder{(sel.SelectedFolderCount == 1 ? "" : "s")}");
            if (sel.SelectedFileCount > 0) parts.Add($"{sel.SelectedFileCount} {(sel.IsLibrary ? "file" : "item")}{(sel.SelectedFileCount == 1 ? "" : "s")}");
            var sub = parts.Count > 0 ? string.Join(" and ", parts) : "selected items";
            _taskName = $"Copy {sub} from {SiteName(_src)} to {SiteName(_tgt)}";
        }
        else
        {
            var next = (History.GetRuns(1).FirstOrDefault()?.Id ?? 0) + 1;
            var what = _batch ? $"{_jobs.Count} lists" : (_list.Length > 0 ? _list : "copy");
            _taskName = $"Copy task {next}: {what}";
        }
        Settings.EnsureLoaded();
        _engine = Settings.DefaultEngine == "MigrationApi" ? "MigrationApi" : "Classic";
        _maxVersions = Math.Clamp(Settings.DefaultMaxVersions, 1, 2000);
    }

    private static string DefaultUrl(string title) => string.Concat(title.Where(char.IsLetterOrDigit));

    // Combine a picked date + optional time as local, return UTC.
    private static DateTime LocalToUtc(DateTime date, DateTime? time)
        => DateTime.SpecifyKind(date.Date.Add(time?.TimeOfDay ?? TimeSpan.Zero), DateTimeKind.Local).ToUniversalTime();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await CheckTargetAsync();
    }

    // Live check of the target list: new / exists / type-mismatch. Non-blocking.
    private async Task CheckTargetAsync()
    {
        if (_batch || string.IsNullOrWhiteSpace(_targetTitle) || string.IsNullOrWhiteSpace(_tgt))
        {
            _targetState = TargetState.Unknown; _targetStateMsg = ""; StateHasChanged(); return;
        }
        var conn = UxConnectionResolver.Find(Settings, _tgt);
        if (conn is null || !UxConnectionResolver.CanResolve(conn, SignIn)) { _targetState = TargetState.Unknown; StateHasChanged(); return; }
        try
        {
            var resolved = UxConnectionResolver.Resolve(conn, _tgt, SignIn);
            var titleEnc = Uri.EscapeDataString(_targetTitle.Trim().Replace("'", "''"));
            using var doc = await resolved.Rest.GetJsonAsync(
                $"{resolved.SiteUrl}/_api/web/lists?$select=Title,BaseType,ItemCount&$filter=Title eq '{titleEnc}'&$top=1");
            var arr = doc.RootElement.GetProperty("value");
            if (arr.GetArrayLength() == 0)
            {
                _targetState = TargetState.New;
                _targetStateMsg = "New — will be created.";
            }
            else
            {
                var tgtIsLibrary = arr[0].GetProperty("BaseType").GetInt32() == 1;
                var count = arr[0].GetProperty("ItemCount").GetInt32();
                var srcIsLibrary = _jobs.Count > 0 && _jobs[0].IsLibrary;
                if (srcIsLibrary != tgtIsLibrary)
                {
                    _targetState = TargetState.Mismatch;
                    _targetStateMsg = $"Exists, but it's a {(tgtIsLibrary ? "library" : "list")} and your source is a {(srcIsLibrary ? "library" : "list")}.";
                }
                else
                {
                    _targetState = TargetState.Exists;
                    _targetStateMsg = $"Exists · {(tgtIsLibrary ? "Library" : "List")} · {count:N0} items — items are added/updated per the mode below.";
                }
            }
        }
        catch { _targetState = TargetState.Unknown; _targetStateMsg = ""; }
        StateHasChanged();
    }

    // Friendly site name for the task title: the /sites/<name> segment, else the host label.
    private static string SiteName(string url)
    {
        try
        {
            var u = new Uri(url.TrimEnd('/'));
            var seg = u.Segments.LastOrDefault()?.Trim('/');
            return string.IsNullOrEmpty(seg) ? u.Host.Split('.')[0] : seg;
        }
        catch { return url; }
    }

    // Live preview of where the list will live on the target as the user types.
    private string FullTargetUrl()
    {
        var path = (string.IsNullOrWhiteSpace(_targetUrl) ? DefaultUrl(_targetTitle) : _targetUrl).Trim().TrimStart('/');
        return $"{_tgt.TrimEnd('/')}/{path}";
    }

    // Queue the task(s) into the background runner and go watch them on Activity.
    // Running in the runner (not this page) means navigating away never cancels them,
    // and several can run at once with the rest queued.
    private void Start()
    {
        if (string.IsNullOrWhiteSpace(_src) || string.IsNullOrWhiteSpace(_tgt) || _jobs.Count == 0)
        {
            Toasts.ShowWarning("Nothing to copy. Go back to the explorer and pick a source.");
            return;
        }
        if (!Migrations.CanRun(_src, _tgt, out var why))
        {
            _statusIntent = MessageIntent.Warning;
            _status = why;
            return;
        }

        var contentOnly = _copyMode == "content";
        var queued = 0;
        foreach (var job in _jobs)
        {
            var title = _batch
                ? (_sameSite ? $"{job.SourceListTitle} - Copy" : job.SourceListTitle)
                : (string.IsNullOrWhiteSpace(_targetTitle) ? job.SourceListTitle : _targetTitle);
            var url = _batch || string.IsNullOrWhiteSpace(_targetUrl) ? DefaultUrl(title) : _targetUrl.Trim();
            var name = _batch ? $"{_taskName} — {job.SourceListTitle}" : _taskName;

            var options = new CopyOptions
            {
                TargetListTitle = title,
                TargetListUrl = url,
                PreserveAuthorsAndDates = _preserve,
                CopyAttachments = _attachments,
                CopyPermissions = _permissions,
                CopyContent = true,
                MergeSchema = !contentOnly,
                CopyViews = !contentOnly,
                CopyListSettings = !contentOnly,
                MaxVersions = _maxVersions,
                SelectedPaths = job.SelectedPaths,
                ItemIds = job.SelectedItemIds,
                ExistingMode = _existingMode switch
                {
                    "CopyIfNewer" => ExistingItemMode.CopyIfNewer,
                    "Skip" => ExistingItemMode.Skip,
                    _ => ExistingItemMode.Overwrite,
                },
                DateField = _dateField == "Created" ? DateFilterField.Created : DateFilterField.Modified,
                // Interpret the picked date/time as LOCAL and convert to UTC (so a day
                // boundary isn't off by the timezone). No time = whole-day inclusive.
                ModifiedSinceUtc = _useDateFilter && _dateFrom.HasValue ? LocalToUtc(_dateFrom.Value, _timeFrom) : null,
                ModifiedBeforeUtc = _useDateFilter && _dateTo.HasValue
                    ? LocalToUtc(_dateTo.Value, _timeTo).Add(_timeTo.HasValue ? TimeSpan.FromSeconds(1) : TimeSpan.FromDays(1))
                    : null,
            };

            Runner.Enqueue(name, _src, _tgt, job.SourceListTitle, options, _engine);
            queued++;
        }

        Toasts.ShowSuccess(queued == 1 ? "Copy queued." : $"{queued} copies queued.");
        Nav.NavigateTo("/activity");
    }
}
