@namespace CleverPoint.Migrator.Ux.Components
@inject HistoryService History
@inject NavigationManager Nav

<FluentCard>
    <FluentToolbar Style="width:100%;">
        <FluentSearch @bind-Value="_filter" @bind-Value:after="Apply" Immediate="true" ImmediateDelay="250"
                      Placeholder="Filter by name, site, list…" />
        <FluentSelect TOption="string" @bind-Value="_statusFilter" @bind-Value:after="Apply"
                      Items="@_statuses" OptionText="@(s => s)" OptionValue="@(s => s)" Style="min-width:200px;" />
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowClockwise())" OnClick="Reload">Refresh</FluentButton>
    </FluentToolbar>

    @if (_view.Count == 0)
    {
        <div class="cp-grid" style="min-height:200px; display:flex; align-items:flex-start; justify-content:center; padding-top:56px;">
            <span class="hint">No migrations match. Runs you start will appear here.</span>
        </div>
    }
    else
    {
        <div class="runs-foot">
            <span class="hint">@_view.Count of @_all.Count runs</span>
            <div class="runs-foot-right">
                @if (ShowPageSize)
                {
                    <span class="hint">Per page</span>
                    <FluentSelect TOption="string" @bind-Value="_perPage" @bind-Value:after="OnPerPageChanged" Style="width:96px;">
                        @foreach (var n in _pageSizes)
                        {
                            <FluentOption Value="@n.ToString()">@n</FluentOption>
                        }
                    </FluentSelect>
                }
                <FluentPaginator State="@_pagination">
                    <SummaryTemplate></SummaryTemplate>
                </FluentPaginator>
            </div>
        </div>

        <div class="cp-grid cp-scroll runs-grid" style="@($"max-height: calc(100vh - {(ShowPageSize ? 320 : 360)}px); min-height:200px;")">
            <FluentDataGrid Items="@_view.AsQueryable()" Pagination="@_pagination" ResizableColumns="true"
                            GenerateHeader="GenerateHeaderOption.Sticky"
                            GridTemplateColumns="56px 2fr 155px 155px 90px 120px 2.4fr" ShowHover="true" Style="width:100%;"
                            OnRowClick="@(async (FluentDataGridRow<Core.History.MigrationRun> r) => { await Task.CompletedTask; if (r.Item is not null) Nav.NavigateTo($"/run/{r.Item.Id}"); })">
                <PropertyColumn Property="@(r => r.Id)" Title="#" Sortable="true" />
                <PropertyColumn Property="@(r => r.Name)" Title="Name" Sortable="true" />
                <PropertyColumn Property="@(r => r.StartedUtc.ToLocalTime())" Title="Started" Format="g" Sortable="true" />
                <PropertyColumn Property="@(r => r.FinishedUtc.HasValue ? r.FinishedUtc.Value.ToLocalTime().ToString("g") : "")" Title="Finished" />
                <PropertyColumn Property="@(r => Duration(r))" Title="Duration" />
                <TemplateColumn Title="Status" Sortable="false">
                    <span class="status-pill @StatusClass(context)">@Pretty(context.Status)</span>
                </TemplateColumn>
                <PropertyColumn Property="@(r => $"{r.Copied} copied · {r.Skipped} skipped · {r.Warnings} warn · {r.Failed} failed")" Title="Result" />
            </FluentDataGrid>
        </div>
    }
</FluentCard>

@code {
    [Parameter] public int PageSize { get; set; } = 50;
    [Parameter] public bool ShowPageSize { get; set; } = true;

    private List<Core.History.MigrationRun> _all = new();
    private List<Core.History.MigrationRun> _view = new();
    private string _filter = "";
    private string _statusFilter = "All statuses";
    private readonly string[] _statuses = { "All statuses", "Completed", "Completed with issues", "Interrupted", "Failed", "Running" };
    private readonly int[] _pageSizes = { 25, 50, 100, 250, 500, 1000 };
    private string _perPage = "50";
    private PaginationState _pagination = new() { ItemsPerPage = 50 };

    protected override void OnInitialized()
    {
        _perPage = PageSize.ToString();
        _pagination = new PaginationState { ItemsPerPage = PageSize };
        Reload();
    }

    public void Reload()
    {
        _all = History.GetRuns();
        Apply();
    }

    private void OnPerPageChanged()
    {
        if (int.TryParse(_perPage, out var n) && n > 0)
            _pagination = new PaginationState { ItemsPerPage = n };
    }

    private void Apply()
    {
        IEnumerable<Core.History.MigrationRun> q = _all;
        if (!string.IsNullOrWhiteSpace(_filter))
        {
            var f = _filter.Trim();
            q = q.Where(r => r.Name.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || r.SourceUrl.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || r.SourceList.Contains(f, StringComparison.OrdinalIgnoreCase)
                          || r.TargetList.Contains(f, StringComparison.OrdinalIgnoreCase));
        }
        if (_statusFilter != "All statuses")
            q = q.Where(r => Pretty(r.Status) == _statusFilter);
        _view = q.ToList();
    }

    private static string Duration(Core.History.MigrationRun r)
    {
        if (r.FinishedUtc is not { } f) return "";
        var d = f - r.StartedUtc;
        return d.TotalHours >= 1 ? $"{(int)d.TotalHours}:{d.Minutes:00}:{d.Seconds:00}" : $"{d.Minutes}:{d.Seconds:00}";
    }

    private static string Pretty(string status) => status == "CompletedWithIssues" ? "Completed with issues" : status;

    // Pill color follows the status label so the two never disagree.
    private static string StatusClass(Core.History.MigrationRun r) => r.Status switch
    {
        "Failed" => "st-failed",
        "CompletedWithIssues" => "st-issues",
        "Interrupted" => "st-interrupted",
        "Running" => "st-running",
        _ => "st-ok",
    };
}
