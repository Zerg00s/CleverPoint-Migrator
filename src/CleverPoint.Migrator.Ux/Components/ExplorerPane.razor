@namespace CleverPoint.Migrator.Ux.Components
@inject UxSettings Settings
@inject SiteBrowser Browser
@inject BrowserSignIn SignIn
@inject IToastService Toasts
@inject DragState Drag
@implements IDisposable

<div class="exp-pane @(!IsSource && Drag.Active ? "drop-ready" : "") @(_dragOver ? "drop-hot" : "")"
     @ondragenter="OnDragEnter" @ondragover="OnDragOver" @ondragover:preventDefault="true"
     @ondragleave="OnDragLeave" @ondrop="OnDrop" @ondrop:preventDefault="true">
    @if (!IsSource && Drag.Active)
    {
        <div class="drop-overlay">
            <FluentIcon Value="@(new Icons.Regular.Size32.ArrowDownload())" />
            @if (Connection is not null && CurrentList is not null)
            {
                <span>Drop to copy @Drag.Count item@(Drag.Count == 1 ? "" : "s") into &ldquo;@CurrentList.Title&rdquo;</span>
            }
            else if (Connection is not null)
            {
                <span>Open a target library or list first, then drop here</span>
            }
            else
            {
                <span>Pick a target connection first</span>
            }
        </div>
    }
    <div class="exp-pane-head">
        <span class="role">@Role</span>
        <div class="exp-row">
            <FluentAutocomplete TOption="string" Style="flex:1 1 auto;" Width="100%"
                                Placeholder="Search or pick a connection…"
                                Items="@_siteChoices" OptionText="@(s => s)"
                                OnOptionsSearch="OnSiteSearch" MaximumSelectedOptions="1"
                                autocomplete="off" name="@($"conn-{Role}")" spellcheck="false"
                                @bind-SelectedOptions="_selectedSites" @bind-SelectedOptions:after="OnSiteSelected" />
            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Add())" Title="Add a connection" @onclick="AddConnection" />
            <FluentButton Appearance="Appearance.Stealth" Loading="_loading" Disabled="@(string.IsNullOrWhiteSpace(_site))"
                          IconStart="@(new Icons.Regular.Size20.ArrowClockwise())"
                          Title="@(CurrentList is not null ? "Refresh this folder" : "Reload this connection")" @onclick="Reload" />
        </div>
    </div>

    <div class="exp-list cp-grid">
        @if (_loading)
        {
            <div class="empty-state" style="padding:40px 16px;"><FluentProgressRing /> <span class="hint">@_status</span></div>
        }
        else if (CurrentList is null && _lists.Count > 0)
        {
            <FluentDataGrid TGridItem="SpListInfo" Items="@_lists.AsQueryable()"
                            GridTemplateColumns="@(IsSource ? "44px 2fr 1fr" : "2fr 1fr")" ShowHover="true" Style="width:100%;"
                            RowClass="@(_ => "click-row")"
                            OnRowClick="@(async (FluentDataGridRow<SpListInfo> r) => { if (r.Item is not null) await OpenList(r.Item); })">
                @if (IsSource)
                {
                    <TemplateColumn Title="">
                        <div @onclick:stopPropagation="true">
                            <FluentCheckbox @bind-Value="context.Selected" @bind-Value:after="OnListTicked"
                                            Title="Tick to copy this whole list/library" />
                        </div>
                    </TemplateColumn>
                }
                <TemplateColumn Title="Name">
                    <div class="entry-cell">
                        <img class="ft-icon" src="@(string.IsNullOrEmpty(context.IconUrl) ? FileIcons.ForList(context) : context.IconUrl)"
                             onerror="@($"this.onerror=null;this.src='{FileIcons.ForList(context)}'")" alt="" />
                        <span class="entry-name">@context.Title</span>
                    </div>
                </TemplateColumn>
                <PropertyColumn Property="@(l => (l.IsLibrary ? "Library" : "List") + ", " + l.ItemCount + " items")" Title="Details" Align="Align.End" />
            </FluentDataGrid>
        }
        else if (CurrentList is not null)
        {
            <div class="exp-crumbs">
                <span class="crumb-up" role="button" @onclick="GoUp"
                      title="@(_crumbs.Count > 1 ? "Up one folder" : "Back to all lists")">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ArrowUp())" /> Up
                </span>
                <span class="crumb-sep">|</span>
                @for (var i = 0; i < _crumbs.Count; i++)
                {
                    var idx = i;
                    <span class="crumb @(idx == _crumbs.Count - 1 ? "current" : "")"
                          role="button" @onclick="@(() => NavigateToCrumb(idx))">@_crumbs[idx].Name</span>
                    @if (idx < _crumbs.Count - 1)
                    {
                        <span class="crumb-sep">/</span>
                    }
                }
            </div>
            <div class="cp-scroll" style="height:100%; border:none;">
                <FluentDataGrid Items="@_items.AsQueryable()" Virtualize="true" ItemSize="32" GenerateHeader="GenerateHeaderOption.Sticky"
                                GridTemplateColumns="@(IsSource ? "44px 2fr 1.3fr 1.3fr" : "2fr 1.3fr 1.3fr")" ShowHover="true" Style="width:100%;"
                                RowClass="@(e => e.IsFolder ? "folder-row" : "")"
                                OnRowClick="@(async (FluentDataGridRow<SpFolderEntry> r) => { if (r.Item?.IsFolder == true) await OpenFolder(r.Item); })">
                    @if (IsSource)
                    {
                        <TemplateColumn Title="">
                            <div @onclick:stopPropagation="true">
                                <FluentCheckbox @bind-Value="context.Selected" @bind-Value:after="@(() => OnEntryTicked(context))"
                                                Title="Tick to copy this item" />
                            </div>
                        </TemplateColumn>
                    }
                    <TemplateColumn Title="Name">
                        <div class="entry-cell" draggable="@(IsSource ? "true" : "false")"
                             @ondragstart="@(() => OnDragStart(context))" @ondragend="OnDragEnd">
                            <img class="ft-icon" src="@FileIcons.ForEntry(context)" alt="" />
                            <span class="entry-name @(context.IsFolder ? "entry-folder" : "")">@context.Name</span>
                            @if (context.IsFolder)
                            {
                                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Class="entry-go" Title="Open" />
                            }
                        </div>
                    </TemplateColumn>
                    <PropertyColumn Property="@(i => i.Modified)" Title="Modified" Sortable="true" Align="Align.End" />
                    <PropertyColumn Property="@(i => i.ModifiedBy)" Title="Modified by" Sortable="true" Align="Align.End" />
                </FluentDataGrid>
            </div>
        }
    </div>
    <div class="exp-status">@_status</div>
</div>

<AddConnectionDialog @ref="_addDialog" OnAdded="OnConnectionAdded" />

@code {
    [Parameter] public string Role { get; set; } = "Source";
    [Parameter] public bool IsSource { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    /// <summary>Raised on the target pane when items are dropped onto it.</summary>
    [Parameter] public EventCallback OnDropRequested { get; set; }

    private AddConnectionDialog? _addDialog;
    private bool _dragOver;

    /// <summary>
    /// Source is ready when a list is open (to pick items) or one or more lists are
    /// ticked (whole-list batch copy). Target is ready when a connection is open.
    /// </summary>
    public bool IsReady => IsSource
        ? (CurrentList is not null || _lists.Any(l => l.Selected))
        : !string.IsNullOrWhiteSpace(_site) && Connection is not null;

    private string? _site;
    private bool _loading;
    private string _status = "Not connected.";
    private List<SpListInfo> _lists = new();
    private List<SpFolderEntry> _items = new();
    private List<string> _siteChoices = new();
    private IEnumerable<string> _selectedSites = new List<string>();

    // Folder navigation within an open library. Crumbs are (display name, folder
    // server-relative URL); the last crumb is the folder currently shown.
    private string _folderUrl = "";
    private readonly List<(string Name, string Url)> _crumbs = new();

    // Selection persists across folder navigation (it spans folders), so it lives
    // in sets keyed by what the engine needs: paths for libraries, IDs for lists.
    private readonly HashSet<string> _pickedPaths = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _pickedFolders = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<int> _pickedIds = new();

    public SpListInfo? CurrentList { get; private set; }
    public string? SiteUrl => _site;
    public SavedConnection? Connection { get; private set; }
    public bool CurrentListIsLibrary => CurrentList?.IsLibrary ?? false;
    public bool HasConnection => Connection is not null;

    /// <summary>Library file/folder paths ticked across all folders (empty = whole list).</summary>
    public List<string> SelectedPaths => _pickedPaths.ToList();

    /// <summary>Generic-list item IDs ticked (empty = whole list).</summary>
    public List<int> SelectedItemIds => _pickedIds.ToList();

    /// <summary>Folder vs file/item counts in the current selection (for naming).</summary>
    public int SelectedFolderCount => CurrentListIsLibrary ? _pickedFolders.Count : 0;
    public int SelectedFileCount => CurrentListIsLibrary ? _pickedPaths.Count - _pickedFolders.Count : _pickedIds.Count;

    /// <summary>Anything ticked inside the open list/library.</summary>
    public bool HasItemSelection => _pickedPaths.Count > 0 || _pickedIds.Count > 0;

    /// <summary>Lists/libraries ticked at the site level for a whole-list batch copy.</summary>
    public List<SpListInfo> SelectedLists => _lists.Where(l => l.Selected).ToList();

    protected override void OnInitialized()
    {
        Settings.EnsureLoaded();
        _siteChoices = Settings.Connections.Select(c => c.SiteUrl.TrimEnd('/')).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        Drag.Changed += OnDragChanged;
    }

    private void OnDragChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Drag.Changed -= OnDragChanged;

    // ---- Drag from source, drop on target -----------------------------------
    private void OnDragStart(SpFolderEntry entry)
    {
        if (!IsSource || CurrentList is null || string.IsNullOrWhiteSpace(_site)) return;
        // Dragging a ticked item drags the whole selection; otherwise just this one.
        List<string> paths; List<int> ids; int folders;
        if (entry.Selected && (_pickedPaths.Count > 0 || _pickedIds.Count > 0))
        {
            paths = _pickedPaths.ToList(); ids = _pickedIds.ToList(); folders = _pickedFolders.Count;
        }
        else if (CurrentList.IsLibrary)
        {
            paths = new() { entry.ServerRelativeUrl }; ids = new(); folders = entry.IsFolder ? 1 : 0;
        }
        else
        {
            paths = new(); ids = new() { entry.ItemId }; folders = 0;
        }
        Drag.Begin(_site!, CurrentList.Title, CurrentList.IsLibrary, paths, ids, folders);
    }

    private void OnDragEnd() => Drag.End();

    private void OnDragEnter() { if (!IsSource && Drag.Active) _dragOver = true; }
    private void OnDragOver() { if (!IsSource && Drag.Active) _dragOver = true; }
    private void OnDragLeave() => _dragOver = false;

    private async Task OnDrop()
    {
        _dragOver = false;
        if (IsSource || !Drag.Active) return;
        if (string.IsNullOrWhiteSpace(_site) || Connection is null)
        {
            _status = "Open a target connection here first, then drop.";
            Drag.End();
            return;
        }
        await OnDropRequested.InvokeAsync();
    }

    // Reload refreshes where you ARE: the open folder/list, not back to the list of
    // lists. Only at the top level does it reload the lists.
    private async Task Reload()
    {
        if (CurrentList is not null) await LoadCurrentAsync();
        else await OpenAsync(forceRefresh: true);
    }

    private async Task OpenAsync(bool forceRefresh = false)
    {
        // With nothing chosen (e.g. no saved connections), Open behaves like the
        // "+" button so the user can add one on the spot.
        if (string.IsNullOrWhiteSpace(_site))
        {
            await AddConnection();
            return;
        }
        Connection = UxConnectionResolver.Find(Settings, _site);
        CurrentList = null;
        _items.Clear();
        if (Connection is null) { _status = "No saved connection for that site."; return; }

        // Browser connections sign in via the WebView2 helper popup, then reuse
        // the captured session for this site and every other on the tenant.
        if (!UxConnectionResolver.IsCert(Connection) && !SignIn.HasSession(_site))
        {
            _loading = true; _status = "Opening sign-in…"; StateHasChanged();
            var (ok, msg) = await SignIn.SignInAsync(_site);
            _loading = false;
            if (!ok) { _status = msg; await OnChanged.InvokeAsync(); return; }
        }

        _loading = true; _status = "Loading lists…"; StateHasChanged();
        try
        {
            var conn = UxConnectionResolver.Resolve(Connection, _site, SignIn);
            _lists = await Browser.GetListsAsync(conn, useCache: !forceRefresh);
            _status = $"{_lists.Count} lists and libraries"
                + (IsSource ? "  ·  tick several to copy them all, or click one to pick items" : "");
        }
        catch (Exception ex) { _status = $"Could not open: {Short(ex.Message)}"; }
        finally { _loading = false; await OnChanged.InvokeAsync(); }
    }

    private async Task OnListTicked()
    {
        var n = _lists.Count(l => l.Selected);
        _status = n > 0
            ? $"{n} ticked to copy  ·  or click a list to pick individual items"
            : $"{_lists.Count} lists and libraries";
        await OnChanged.InvokeAsync();
    }

    // Contains-search (not just prefix): match anywhere in the connection URL.
    private void OnSiteSearch(OptionsSearchEventArgs<string> e)
    {
        var t = e.Text?.Trim() ?? "";
        e.Items = string.IsNullOrEmpty(t)
            ? _siteChoices
            : _siteChoices.Where(s => s.Contains(t, StringComparison.OrdinalIgnoreCase));
    }

    // Picking a connection from the list opens it straight away (no Open click needed).
    private async Task OnSiteSelected()
    {
        var pick = _selectedSites?.FirstOrDefault();
        if (string.IsNullOrWhiteSpace(pick) || pick == _site) return;
        _site = pick;
        await OpenAsync();
    }

    private async Task GoUp()
    {
        if (_crumbs.Count > 1) await NavigateToCrumb(_crumbs.Count - 2);
        else await BackToLists();
    }

    private async Task AddConnection()
    {
        if (_addDialog is not null) await _addDialog.OpenAsync();
    }

    private async Task OnConnectionAdded(SavedConnection c)
    {
        _siteChoices = Settings.Connections.Select(x => x.SiteUrl.TrimEnd('/')).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        _site = c.SiteUrl;
        _selectedSites = new List<string> { c.SiteUrl };
        await OpenAsync();
    }

    private async Task OpenList(SpListInfo list)
    {
        if (Connection is null || _site is null) return;
        CurrentList = list;
        _pickedPaths.Clear(); _pickedFolders.Clear(); _pickedIds.Clear();
        _crumbs.Clear();
        _crumbs.Add((list.Title, list.ServerRelativeUrl));
        _folderUrl = list.ServerRelativeUrl;
        await LoadCurrentAsync();
    }

    private async Task OpenFolder(SpFolderEntry entry)
    {
        if (!entry.IsFolder || CurrentList is null) return;
        _crumbs.Add((entry.Name, entry.ServerRelativeUrl));
        _folderUrl = entry.ServerRelativeUrl;
        await LoadCurrentAsync();
    }

    private async Task NavigateToCrumb(int index)
    {
        if (index < 0 || index >= _crumbs.Count) return;
        if (index < _crumbs.Count - 1) _crumbs.RemoveRange(index + 1, _crumbs.Count - index - 1);
        _folderUrl = _crumbs[index].Url;
        await LoadCurrentAsync();
    }

    /// <summary>Loads the current folder (library) or the item list (generic list).</summary>
    private async Task LoadCurrentAsync()
    {
        if (CurrentList is null || Connection is null || _site is null) return;
        var here = _crumbs.Count > 0 ? _crumbs[^1].Name : CurrentList.Title;
        _loading = true; _status = $"Loading {here}…"; StateHasChanged();
        try
        {
            var conn = UxConnectionResolver.Resolve(Connection, _site, SignIn);
            if (CurrentList.IsLibrary)
            {
                _items = await Browser.GetFolderAsync(conn, _folderUrl, CurrentList.ServerRelativeUrl);
                foreach (var e in _items) e.Selected = _pickedPaths.Contains(e.ServerRelativeUrl);
            }
            else
            {
                _items = await Browser.GetListItemsAsync(conn, CurrentList);
                foreach (var e in _items) e.Selected = _pickedIds.Contains(e.ItemId);
            }
            _status = BuildItemStatus();
        }
        catch (Exception ex) { _status = $"Could not open {here}: {Short(ex.Message)}"; }
        finally { _loading = false; await OnChanged.InvokeAsync(); }
    }

    private async Task OnEntryTicked(SpFolderEntry entry)
    {
        if (CurrentList?.IsLibrary == true)
        {
            if (entry.Selected)
            {
                _pickedPaths.Add(entry.ServerRelativeUrl);
                if (entry.IsFolder) _pickedFolders.Add(entry.ServerRelativeUrl);
            }
            else
            {
                _pickedPaths.Remove(entry.ServerRelativeUrl);
                _pickedFolders.Remove(entry.ServerRelativeUrl);
            }
        }
        else
        {
            if (entry.Selected) _pickedIds.Add(entry.ItemId);
            else _pickedIds.Remove(entry.ItemId);
        }
        _status = BuildItemStatus();
        await OnChanged.InvokeAsync();
    }

    private string BuildItemStatus()
    {
        var here = _crumbs.Count > 1 ? _crumbs[^1].Name : (CurrentList?.Title ?? "");
        var capped = _items.Count >= Browser.MaxItemsLoaded;
        var count = capped ? $"first {Browser.MaxItemsLoaded:N0} shown" : $"{_items.Count:N0} items";
        var picked = _pickedPaths.Count + _pickedIds.Count;
        var s = $"{here}: {count}";
        if (!IsSource) return s;
        s += picked > 0
            ? $"  ·  {picked} selected to copy"
            : (CurrentList?.IsLibrary == true
                ? "  ·  open folders to browse, tick items to copy (none = whole library)"
                : "  ·  tick items to copy (none = whole list)");
        if (capped) s += "  ·  open a folder to narrow down";
        return s;
    }

    private async Task BackToLists()
    {
        CurrentList = null; _items.Clear(); _crumbs.Clear();
        _pickedPaths.Clear(); _pickedFolders.Clear(); _pickedIds.Clear();
        _status = $"{_lists.Count} lists and libraries"
            + (IsSource ? "  ·  tick several to copy them all, or click one to open it" : "");
        await OnChanged.InvokeAsync();
    }

    private static string Short(string m) => m.Length > 140 ? m[..140] + "…" : m;
}
